---
import type { SupportedLocale } from '../../i18n/utils/types';
import { LOCALES } from '../../i18n/utils/types';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { insightsData } from '../../data/insights';
import InsightsHero from '../../components/sections/insights/InsightsHero.astro';
import InsightsCategories from '../../components/sections/insights/InsightsCategories.astro';
import InsightsFeatured from '../../components/sections/insights/InsightsFeatured.astro';
import InsightsGrid from '../../components/sections/insights/InsightsGrid.astro';
import InsightsTrends from '../../components/sections/insights/InsightsTrends.astro';
import InsightsCases from '../../components/sections/insights/InsightsCases.astro';
import InsightsResources from '../../components/sections/insights/InsightsResources.astro';
import InsightsCTA from '../../components/sections/insights/InsightsCTA.astro';

export function getStaticPaths() {
  return LOCALES.map((locale) => ({
    params: { lang: locale },
    props: { locale },
  }));
}

const { locale } = Astro.props;

const meta: Record<string, { title: string; description: string }> = {
  es: { title: 'Insights - SABERO Consulting', description: 'Contenidos para lideres de negocio y equipos que buscan entender producto digital, automatizacion, escalabilidad y evolucion tecnologica.' },
  en: { title: 'Insights - SABERO Consulting', description: 'Content for business leaders and teams looking to understand digital product, automation, scalability and technology evolution.' },
  pt: { title: 'Insights - SABERO Consulting', description: 'Conteudo para lideres de negocios e equipes que buscam entender produto digital, automacao, escalabilidade e evolucao tecnologica.' },
  fr: { title: 'Insights - SABERO Consulting', description: 'Contenus pour les dirigeants et les equipes qui cherchent a comprendre le produit numerique, l\'automatisation, l\'evolutivite et l\'evolution technologique.' },
};

const pageMeta = meta[locale as string] || meta.es;
const path = `/${locale}/insights`;
const data = insightsData[locale as string] || insightsData.es;

const sectionTitles: Record<string, { featured: string; articles: string; trends: string; cases: string; resources: string }> = {
  es: { featured: 'Destacados', articles: 'Articulos y guias', trends: 'Tendencias', cases: 'Casos comentados', resources: 'Recursos descargables' },
  en: { featured: 'Featured', articles: 'Articles and guides', trends: 'Trends', cases: 'Case studies', resources: 'Resources' },
  pt: { featured: 'Destaques', articles: 'Artigos e guias', trends: 'Tendencias', cases: 'Casos comentados', resources: 'Recursos para download' },
  fr: { featured: 'Incontournables', articles: 'Articles et guides', trends: 'Tendances', cases: 'Etudes de cas', resources: 'Ressources' },
};

const titles = sectionTitles[locale as string] || sectionTitles.es;
---

<BaseLayout title={pageMeta.title} description={pageMeta.description} locale={locale as SupportedLocale} path={path}>
  <InsightsHero data={data.hero} locale={locale} />
  <InsightsCategories categories={data.categories} activeCategory="all" />
  <InsightsFeatured featured={data.featured} />
  <InsightsGrid articles={data.articles} title={titles.articles} />
  <InsightsTrends trends={data.trends} title={titles.trends} />
  <InsightsCases cases={data.cases} title={titles.cases} />
  <InsightsResources resources={data.resources} title={titles.resources} />
  <InsightsCTA data={data.cta} locale={locale} />
</BaseLayout>
