---
import type { SupportedLocale } from '../../i18n/utils/types';
import { LOCALES } from '../../i18n/utils/types';
import BaseLayout from '../../layouts/BaseLayout.astro';

export function getStaticPaths() {
  return LOCALES.map((locale) => ({
    params: { lang: locale },
    props: { locale },
  }));
}

const { locale } = Astro.props;

const meta: Record<string, { title: string; description: string }> = {
  es: { title: 'Casos e impacto - SABERO Consulting', description: 'Conoce como transformamos retos de negocio en productos, plataformas y operaciones digitales medibles.' },
  en: { title: 'Cases & Impact - SABERO Consulting', description: 'See how we transform business challenges into measurable digital products, platforms and operations.' },
  pt: { title: 'Casos e impacto - SABERO Consulting', description: 'Veja como transformamos desafios de negocios em produtos, plataformas e operacoes digitais viaveis.' },
  fr: { title: 'Cas et impact - SABERO Consulting', description: 'Decouvrez comment nous transformons les defis commerciaux en produits, plateformes et operations numeriques mesurables.' },
};

const pageMeta = meta[locale as string] || meta.es;
const path = `/${locale}/casos`;
---

<BaseLayout title={pageMeta.title} description={pageMeta.description} locale={locale as SupportedLocale} path={path}>
  <section class="page-header section">
    <div class="container">
      <h1>{locale === 'es' ? 'Casos e impacto' : locale === 'en' ? 'Cases & Impact' : locale === 'pt' ? 'Casos e impacto' : 'Cas et impact'}</h1>
      <p class="section-subtitle">{pageMeta.description}</p>
    </div>
  </section>
  <section class="section">
    <div class="container">
      <p class="text-tertiary">{locale === 'es' ? 'Proximamente: casos de estudio detallados.' : locale === 'en' ? 'Coming soon: detailed case studies.' : locale === 'pt' ? 'Em breve: estudos de caso detalhados.' : 'Prochainement: etudes de cas detaillees.'}</p>
    </div>
  </section>
</BaseLayout>
