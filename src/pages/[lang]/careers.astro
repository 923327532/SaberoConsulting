---
import type { SupportedLocale } from '../../i18n/utils/types';
import { LOCALES } from '../../i18n/utils/types';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCareersData } from '../../data/careers/index';
import CareersHero from '../../components/sections/careers/CareersHero.astro';
import WhySabero from '../../components/sections/careers/WhySabero.astro';
import LifeAtSabero from '../../components/sections/careers/LifeAtSabero.astro';
import TeamsGrid from '../../components/sections/careers/TeamsGrid.astro';
import GrowthLearning from '../../components/sections/careers/GrowthLearning.astro';
import InclusionCulture from '../../components/sections/careers/InclusionCulture.astro';
import HiringProcess from '../../components/sections/careers/HiringProcess.astro';
import OpenPositions from '../../components/sections/careers/OpenPositions.astro';
import FutureTalent from '../../components/sections/careers/FutureTalent.astro';

export function getStaticPaths() {
  return LOCALES.map((locale) => ({
    params: { lang: locale },
    props: { locale },
  }));
}

const { locale } = Astro.props;

const meta: Record<string, { title: string; description: string }> = {
  es: { title: 'Careers - SABERO Consulting', description: 'Sumate a un equipo que construye productos digitales con foco en ingenieria, negocio y evolucion continua.' },
  en: { title: 'Careers - SABERO Consulting', description: 'Join a team that builds digital products with a focus on engineering, business and continuous evolution.' },
  pt: { title: 'Carreiras - SABERO Consulting', description: 'Junte-se a uma equipe que constroi produtos digitais com foco em engenharia, negocios e evolucao continua.' },
  fr: { title: 'Carrieres - SABERO Consulting', description: 'Rejoignez une equipe qui construit des produits numeriques axes sur l\'ingenierie, les affaires et l\'evolution continue.' },
};

const pageMeta = meta[locale as string] || meta.es;
const path = `/${locale}/careers`;
const data = getCareersData(locale as SupportedLocale);
---

<BaseLayout title={pageMeta.title} description={pageMeta.description} locale={locale as SupportedLocale} path={path}>
  <CareersHero data={data.hero} locale={locale} />
  <WhySabero data={data.whySabero} />
  <LifeAtSabero data={data.lifeAtSabero} />
  <TeamsGrid data={data.teams} />
  <GrowthLearning data={data.growth} />
  <InclusionCulture data={data.inclusion} />
  <HiringProcess data={data.process} />
  <OpenPositions data={data.opportunities} locale={locale} />
  <FutureTalent data={data.futureTalent} locale={locale} />
</BaseLayout>
