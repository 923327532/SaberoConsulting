---
import type { SupportedLocale } from '../../i18n/utils/types';
import { LOCALES } from '../../i18n/utils/types';
import BaseLayout from '../../layouts/BaseLayout.astro';
import IndustriesSection from '../../components/sections/industries/IndustriesSection.astro';

export function getStaticPaths() {
  return LOCALES.map((locale) => ({
    params: { lang: locale },
    props: { locale },
  }));
}

const { locale } = Astro.props;

const meta: Record<string, { title: string; description: string }> = {
  es: {
    title: 'Industrias - SABERO Consulting',
    description: 'Cada industria tiene procesos, metricas y retos distintos. SABERO adapta producto, arquitectura y experiencia segun ese contexto.',
  },
  en: {
    title: 'Industries - SABERO Consulting',
    description: 'Each industry has distinct processes, metrics and challenges. SABERO adapts product, architecture and experience to that context.',
  },
  pt: {
    title: 'Industrias - SABERO Consulting',
    description: 'Cada industria tem processos, metricas e desafios distintos. A SABERO adapta produto, arquitetura e experiencia a esse contexto.',
  },
  fr: {
    title: 'Industries - SABERO Consulting',
    description: 'Chaque industrie a des processus, des metriques et des defis distincts. SABERO adapte le produit, l\'architecture et l\'experience a ce contexte.',
  },
};

const pageMeta = meta[locale as string] || meta.es;
const path = `/${locale}/industrias`;

---

<BaseLayout
  title={pageMeta.title}
  description={pageMeta.description}
  locale={locale as SupportedLocale}
  path={path}
>
  <IndustriesSection locale={locale as SupportedLocale} />
</BaseLayout>
