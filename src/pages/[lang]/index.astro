---
import type { SupportedLocale } from '../../i18n/utils/types';
import { LOCALES } from '../../i18n/utils/types';
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroCarousel from '../../components/sections/HeroCarousel.astro';
import HomeHeroSection from '../../components/sections/home/HomeHeroSection.astro';
import CloudPlatformSection from '../../components/sections/CloudPlatformSection.astro';
import HomeOfertaResumen from '../../components/sections/home/HomeOfertaResumen.astro';
import HomeIndustriesResumen from '../../components/sections/home/HomeIndustriesResumen.astro';
import HomeCareersResumen from '../../components/sections/home/HomeCareersResumen.astro';
import HomeTechStack from '../../components/sections/home/HomeTechStack.astro';
import CTASection from '../../components/sections/CTASection.astro';

export function getStaticPaths() {
  return LOCALES.map((locale) => ({
    params: { lang: locale },
    props: { locale },
  }));
}

const { locale } = Astro.props;

const meta: Record<string, { title: string; description: string }> = {
  es: {
    title: 'SABERO Consulting - Ingenieria de Productos Digitales y Evolucion de Plataformas',
    description: 'SABERO Consulting disena, desarrolla y evoluciona plataformas digitales para empresas que necesitan escalar procesos, productos y operaciones en America y Europa.',
  },
  en: {
    title: 'SABERO Consulting - Digital Product Engineering & Platform Evolution',
    description: 'SABERO Consulting designs, develops and evolves digital platforms for companies that need to scale processes, products and operations across America and Europe.',
  },
  pt: {
    title: 'SABERO Consulting - Engenharia de Produtos Digitais & Evolucao de Plataformas',
    description: 'A SABERO Consulting projeta, desenvolve e evolui plataformas digitais para empresas que precisam escalar processos, produtos e operacoes na America e Europa.',
  },
  fr: {
    title: 'SABERO Consulting - Ingenierie de Produits Numeriques & Evolution de Plateformes',
    description: 'SABERO Consulting concoit, developpe et fait evoluer des plateformes numeriques pour les entreprises qui doivent passer a l\'echelle leurs processus, produits et operations en Amerique et en Europe.',
  },
};

const pageMeta = meta[locale as string] || meta.es;
const path = '/';

---

<BaseLayout
  title={pageMeta.title}
  description={pageMeta.description}
  locale={locale as SupportedLocale}
  path={path}
>
  <HeroCarousel locale={locale as SupportedLocale} />
  <HomeHeroSection locale={locale as string} />
  <HomeCareersResumen locale={locale as string} />
  <HomeTechStack locale={locale as string} />
  <CloudPlatformSection locale={locale as string} />
  <HomeOfertaResumen locale={locale as string} />
  <HomeIndustriesResumen locale={locale as SupportedLocale} />
  <CTASection locale={locale as string} />
</BaseLayout>
