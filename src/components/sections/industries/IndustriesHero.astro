---
// ============================================
// SABERO Consulting - Industries Hero
// Intro general + índice visual de sectores
// ============================================
import type { IndustriesData } from '../../../data/industries/types';

interface Props {
  content: IndustriesData;
}

const { content } = Astro.props;
const { sectors } = content;
---

<section class="industries-hero" id="industrias" aria-label={content.title}>
  <div class="container">
    <!-- Intro -->
    <div class="industries-hero-intro">
      <div class="industries-hero-intro-grid">
        <div class="industries-hero-intro-left">
          <span class="industries-hero-eyebrow">Expertise sectorial</span>
          <h2 class="industries-hero-title">{content.title}</h2>
        </div>
        <div class="industries-hero-intro-right">
          <p class="industries-hero-subtitle">{content.subtitle}</p>
        </div>
      </div>
    </div>

    <!-- Índice visual -->
    <div class="industries-hero-index">
      <div class="industries-hero-index-grid">
        {sectors.map((sector, i) => (
          <a href={`#${sector.id}`} class="industries-hero-index-item">
            <span class="industries-hero-index-num">0{i + 1}</span>
            <span class="industries-hero-index-label">{sector.title}</span>
            <svg class="industries-hero-index-arrow" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M2 7h10M7 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .industries-hero {
    background: #FFFFFF;
    padding: 120px 0 0;
  }

  .industries-hero-intro {
    padding-bottom: 80px;
  }

  .industries-hero-intro-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 60px;
    align-items: start;
  }

  .industries-hero-eyebrow {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: #2F80FF;
    background: #F0F5FF;
    padding: 4px 12px;
    border-radius: 4px;
    margin-bottom: 20px;
  }

  .industries-hero-title {
    font-size: clamp(2.2rem, 4vw, 3.5rem);
    font-weight: 800;
    color: #0A1628;
    margin: 0;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  .industries-hero-subtitle {
    font-size: 1rem;
    line-height: 1.8;
    color: #5E6472;
    margin: 0;
    max-width: 540px;
  }

  .industries-hero-index {
    padding-bottom: 80px;
  }

  .industries-hero-index-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }

  .industries-hero-index-item {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 16px 20px;
    border: 1px solid #E8ECF2;
    border-radius: 10px;
    text-decoration: none;
    transition: all 300ms ease;
    background: #FFFFFF;
  }

  .industries-hero-index-item:hover {
    border-color: #2F80FF;
    background: #F8FAFF;
    box-shadow: 0 4px 16px rgba(47, 128, 255, 0.08);
  }

  .industries-hero-index-num {
    font-size: 0.7rem;
    font-weight: 700;
    color: #2F80FF;
    background: #F0F5FF;
    padding: 3px 8px;
    border-radius: 4px;
    letter-spacing: 1px;
    flex-shrink: 0;
  }

  .industries-hero-index-label {
    font-size: 0.85rem;
    font-weight: 600;
    color: #0A1628;
    flex: 1;
  }

  .industries-hero-index-arrow {
    color: #C8D0DC;
    flex-shrink: 0;
    transition: transform 300ms ease, color 300ms ease;
  }

  .industries-hero-index-item:hover .industries-hero-index-arrow {
    transform: translateX(3px);
    color: #2F80FF;
  }

  @media (max-width: 1024px) {
    .industries-hero-intro-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .industries-hero-index-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .industries-hero { padding: 80px 0 0; }
    .industries-hero-intro { padding-bottom: 48px; }
    .industries-hero-index { padding-bottom: 48px; }
    .industries-hero-index-grid { grid-template-columns: 1fr; }
  }
</style>
