---
// ============================================
// SABERO Consulting - PropTech Sector
// ============================================
import type { IndustrySector } from '../../../data/industries/types';

interface Props {
  sector: IndustrySector;
  index: number;
  isLast: boolean;
}

const { sector, index, isLast } = Astro.props;
---

<article class="industry-block" id={sector.id}>
  <div class="container">
    <!-- Header -->
    <div class="industry-block-header">
      <span class="industry-block-number">0{index + 1}</span>
      <h3 class="industry-block-title">{sector.title}</h3>
    </div>

    <!-- Contexto -->
    <div class="industry-block-context">
      <p class="industry-block-context-text">{sector.context}</p>
    </div>

    <!-- Grid: Retos + Soluciones -->
    <div class="industry-block-grid">
      <div class="industry-block-col">
        <div class="industry-block-col-header">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <circle cx="8" cy="8" r="7" stroke="#2F80FF" stroke-width="1.2"/>
            <path d="M8 5v3.5M8 11v.5" stroke="#2F80FF" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <h4 class="industry-block-col-title">Retos del sector</h4>
        </div>
        <ul class="industry-block-list">
          {sector.challenges.map((ch) => (
            <li class="industry-block-list-item">{ch}</li>
          ))}
        </ul>
      </div>

      <div class="industry-block-col">
        <div class="industry-block-col-header">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M8 1v14M1 8h14" stroke="#2F80FF" stroke-width="1.5" stroke-linecap="round"/>
            <circle cx="8" cy="8" r="3" fill="#2F80FF" opacity="0.2"/>
          </svg>
          <h4 class="industry-block-col-title">Soluciones SABERO</h4>
        </div>
        <ul class="industry-block-list">
          {sector.solutions.map((sol) => (
            <li class="industry-block-list-item">{sol}</li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Capacidades relacionadas -->
    <div class="industry-block-capabilities">
      <span class="industry-block-capabilities-label">Capacidades relacionadas</span>
      <div class="industry-block-capabilities-tags">
        {sector.capabilities.map((cap) => (
          <span class="industry-block-capabilities-tag">{cap}</span>
        ))}
      </div>
    </div>

    <!-- CTA -->
    <div class="industry-block-cta">
      <a href={sector.ctaHref} class="industry-block-cta-link">
        {sector.cta}
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M2 7h10M7 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>

  {!isLast && (
    <div class="industry-block-divider">
      <div class="container">
        <div class="industry-block-divider-line"></div>
      </div>
    </div>
  )}
</article>

<style>
  .industry-block {
    padding: 0;
    background: #FFFFFF;
  }

  .industry-block-header {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 32px;
    padding-bottom: 20px;
    border-bottom: 1px solid #E8ECF2;
  }

  .industry-block-number {
    font-size: 0.7rem;
    font-weight: 700;
    color: #2F80FF;
    letter-spacing: 2px;
    background: #F0F5FF;
    padding: 4px 12px;
    border-radius: 4px;
    flex-shrink: 0;
  }

  .industry-block-title {
    font-size: 1.8rem;
    font-weight: 700;
    color: #0A1628;
    margin: 0;
    letter-spacing: -0.02em;
  }

  .industry-block-context {
    margin-bottom: 40px;
    max-width: 780px;
  }

  .industry-block-context-text {
    font-size: 1rem;
    line-height: 1.8;
    color: #3A4050;
    margin: 0;
  }

  .industry-block-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    margin-bottom: 40px;
  }

  .industry-block-col {
    border: 1px solid #E8ECF2;
    border-radius: 14px;
    padding: 32px 28px;
    background: #FAFBFC;
    transition: all 300ms ease;
  }

  .industry-block-col:hover {
    border-color: #D0D8E4;
    box-shadow: 0 4px 20px rgba(0,0,0,0.03);
  }

  .industry-block-col-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 20px;
  }

  .industry-block-col-title {
    font-size: 0.9rem;
    font-weight: 700;
    color: #0A1628;
    margin: 0;
  }

  .industry-block-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .industry-block-list-item {
    font-size: 0.85rem;
    line-height: 1.6;
    color: #3A4050;
    padding-left: 18px;
    position: relative;
  }

  .industry-block-list-item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 9px;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #2F80FF;
    opacity: 0.35;
  }

  .industry-block-capabilities {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 32px;
    padding: 20px 24px;
    background: #F8F9FB;
    border-radius: 10px;
    border-left: 3px solid #2F80FF;
  }

  .industry-block-capabilities-label {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: #2F80FF;
    flex-shrink: 0;
  }

  .industry-block-capabilities-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .industry-block-capabilities-tag {
    font-size: 0.78rem;
    color: #3A4050;
    background: #FFFFFF;
    border: 1px solid #E0E4EC;
    padding: 4px 14px;
    border-radius: 20px;
    font-weight: 500;
    transition: all 250ms ease;
  }

  .industry-block-capabilities-tag:hover {
    border-color: #2F80FF;
    color: #2F80FF;
    background: #F0F5FF;
  }

  .industry-block-cta {
    margin-bottom: 0;
  }

  .industry-block-cta-link {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 0.85rem;
    font-weight: 600;
    color: #2F80FF;
    text-decoration: none;
    padding: 10px 20px;
    border: 1px solid #2F80FF;
    border-radius: 8px;
    transition: all 300ms ease;
  }

  .industry-block-cta-link:hover {
    background: #2F80FF;
    color: #FFFFFF;
    box-shadow: 0 4px 16px rgba(47, 128, 255, 0.2);
  }

  .industry-block-cta-link svg {
    transition: transform 300ms ease;
  }

  .industry-block-cta-link:hover svg {
    transform: translateX(3px);
  }

  .industry-block-divider {
    padding: 80px 0;
  }

  .industry-block-divider-line {
    height: 1px;
    background: linear-gradient(90deg, transparent, #D0D8E4, transparent);
  }

  @media (max-width: 1024px) {
    .industry-block-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 640px) {
    .industry-block-title { font-size: 1.4rem; }
    .industry-block-col { padding: 24px 20px; }
    .industry-block-capabilities { flex-direction: column; align-items: flex-start; gap: 10px; }
    .industry-block-divider { padding: 48px 0; }
  }
</style>
