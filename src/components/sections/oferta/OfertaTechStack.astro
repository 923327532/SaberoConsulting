---

<section class="tech-stack-section" id="tech-stack">
  <div class="tech-stack-container">
    <h2 class="tech-stack-title">Tech stack</h2>
    <div class="tech-stack-divider"></div>
    <div class="tech-stack-grid">
      {techCategories.map((cat) => (
        <details class="tech-stack-block" name="tech-accordion">
          <summary class="tech-stack-summary">
            <span class="tech-stack-summary-inner">
              <span class="tech-stack-icon" set:html={cat.icon}></span>
              <span class="tech-stack-label">{cat.title}</span>
            </span>
            <span class="tech-stack-arrow">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="6 9 12 15 18 9" />
              </svg>
            </span>
          </summary>
          <div class="tech-stack-content">
            <p class="tech-stack-desc">{cat.description}</p>
            <ul class="tech-stack-list">
              {cat.items.map((item) => (
                <li class="tech-stack-item">
                  {item.logoUrl && !item.logoUrl.startsWith('data:') ? (
                    <img class="tech-stack-logo" src={item.logoUrl} alt={item.name} width="20" height="20" loading="lazy" onerror="this.style.display='none'" />
                  ) : (
                    <span class="tech-stack-logo-fallback">{item.name.charAt(0)}</span>
                  )}
                  <span>{item.name}</span>
                </li>
              ))}
            </ul>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<script>
  // Accordion: solo un bloque abierto a la vez
  document.addEventListener('click', (e) => {
    if (!(e.target instanceof HTMLElement)) return;
    const summary = e.target.closest('.tech-stack-summary');
    if (!summary) return;

    const details = /** @type {HTMLDetailsElement} */ (summary.closest('details'));
    if (!details) return;

    // Cerrar todos los demás
    document.querySelectorAll('.tech-stack-block[open]').forEach((el) => {
      if (el !== details) {
        el.removeAttribute('open');
      }
    });
  });
</script>

<style is:global>
  .tech-stack-section {
    padding: 5rem 0;
    background: #ffffff;
  }
  .tech-stack-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .tech-stack-title {
    font-size: 2.5rem;
    font-weight: 700;
    text-align: center;
    margin: 0 0 0.75rem;
    color: #111827;
    letter-spacing: -0.02em;
  }
  .tech-stack-divider {
    width: 80px;
    height: 4px;
    margin: 0 auto 3rem;
    border-radius: 2px;
    background: linear-gradient(90deg, #2F80FF, #0B2F7D, #E53935);
  }
  .tech-stack-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }
  .tech-stack-block {
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    overflow: hidden;
    background: #fafafa;
    background-image: url('https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcTHCWVGfsbCcenQoMbXtOgOcL6F5AFA46KiBA&s');
    background-size: cover;
    background-position: center;
    background-blend-mode: overlay;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .tech-stack-block:hover {
    border-color: #2F80FF;
    box-shadow: 0 2px 12px rgba(47, 128, 255, 0.08);
  }
  .tech-stack-block[open] {
    border-color: #2F80FF;
    box-shadow: 0 4px 20px rgba(47, 128, 255, 0.12);
    background: #ffffff;
  }
  .tech-stack-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.25rem;
    cursor: pointer;
    list-style: none;
    user-select: none;
    gap: 0.75rem;
  }
  .tech-stack-summary::-webkit-details-marker {
    display: none;
  }
  .tech-stack-summary-inner {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    min-width: 0;
  }
  .tech-stack-icon {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: rgba(47, 128, 255, 0.08);
  }
  .tech-stack-label {
    font-size: 0.95rem;
    font-weight: 600;
    color: #111827;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .tech-stack-arrow {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    color: #9ca3af;
    transition: transform 0.3s ease;
  }
  .tech-stack-block[open] .tech-stack-arrow {
    transform: rotate(180deg);
    color: #2F80FF;
  }
  .tech-stack-content {
    padding: 0 1.25rem 1.25rem;
    animation: techFadeIn 0.25s ease;
  }
  @keyframes techFadeIn {
    from { opacity: 0; transform: translateY(-6px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .tech-stack-desc {
    font-size: 0.85rem;
    color: #6b7280;
    margin: 0 0 1rem;
    line-height: 1.5;
  }
  .tech-stack-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
  }
  .tech-stack-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.6rem;
    font-size: 0.85rem;
    font-weight: 500;
    color: #374151;
    background: #f3f4f6;
    border-radius: 6px;
    transition: background 0.15s;
  }
  .tech-stack-item:hover {
    background: #e5e7eb;
  }
  .tech-stack-logo {
    width: 18px;
    height: 18px;
    object-fit: contain;
    flex-shrink: 0;
  }
  .tech-stack-logo-fallback {
    width: 18px;
    height: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-size: 0.65rem;
    font-weight: 700;
    color: #2F80FF;
    background: rgba(47, 128, 255, 0.1);
    border-radius: 4px;
  }
  @media (max-width: 1024px) {
    .tech-stack-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .tech-stack-section { padding: 3rem 0; }
    .tech-stack-title { font-size: 1.75rem; }
    .tech-stack-grid { grid-template-columns: 1fr; }
    .tech-stack-list { grid-template-columns: 1fr; }
  }
</style>
