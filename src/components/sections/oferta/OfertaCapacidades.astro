---
// ============================================
// SABERO Consulting - Capacidades
// Bloque 2: Capacidades estratégicas premium
// Cada card: título, descripción, qué resuelve
// ============================================
import { ofertaContent } from '../../../data/home/oferta';

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const content = ofertaContent[locale] || ofertaContent.es;
const { capacidades } = content;
---

<section class="capacidades">
  <div class="container">
    <div class="capacidades-header">
      <span class="capacidades-number">01</span>
      <h3 class="capacidades-title">{capacidades.title}</h3>
      <p class="capacidades-subtitle">{capacidades.subtitle}</p>
    </div>

    <div class="capacidades-grid">
      {capacidades.items.map((item, i) => (
        <article class="cap-card" id={item.id}>
          <div class="cap-card-num-wrap">
            <span class="cap-card-num">0{i + 1}</span>
          </div>
          <h4 class="cap-card-title">{item.title}</h4>
          <p class="cap-card-summary">{item.summary}</p>
          <div class="cap-card-resolves">
            <span class="cap-card-resolves-label">Qué resuelve</span>
            <p class="cap-card-resolves-text">{item.resolves}</p>
          </div>
          <ul class="cap-card-list">
            {item.items.map((sub) => (
              <li class="cap-card-item">{sub}</li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .capacidades {
    padding: 120px 0 140px;
    background: #FFFFFF;
    position: relative;
  }

  .capacidades::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: calc(100% - 48px);
    max-width: 1200px;
    height: 1px;
    background: linear-gradient(90deg, transparent, #D0D8E4, transparent);
  }

  .capacidades-header {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 56px;
    padding-bottom: 24px;
    border-bottom: 1px solid #E8ECF2;
  }

  .capacidades-number {
    font-size: 0.7rem;
    font-weight: 700;
    color: #2F80FF;
    letter-spacing: 2px;
    background: #F0F5FF;
    padding: 4px 12px;
    border-radius: 4px;
  }

  .capacidades-title {
    font-size: 1.8rem;
    font-weight: 700;
    color: #0A1628;
    margin: 0;
    letter-spacing: -0.02em;
  }

  .capacidades-subtitle {
    font-size: 0.9rem;
    color: #5E6472;
    margin: 0 0 0 auto;
  }

  .capacidades-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }

  .cap-card {
    border: 1px solid #E8ECF2;
    border-radius: 16px;
    padding: 36px 32px;
    background: #FFFFFF;
    transition: all 350ms ease;
    display: flex;
    flex-direction: column;
  }

  .cap-card:hover {
    border-color: #C8D0DC;
    box-shadow: 0 8px 28px rgba(0,0,0,0.05);
    transform: translateY(-3px);
  }

  .cap-card-num-wrap {
    margin-bottom: 20px;
  }

  .cap-card-num {
    font-size: 0.75rem;
    font-weight: 700;
    color: #2F80FF;
    background: #F0F5FF;
    padding: 3px 10px;
    border-radius: 4px;
    letter-spacing: 1px;
  }

  .cap-card-title {
    font-size: 1.15rem;
    font-weight: 700;
    color: #0A1628;
    margin: 0 0 14px;
    line-height: 1.3;
  }

  .cap-card-summary {
    font-size: 0.88rem;
    line-height: 1.7;
    color: #5E6472;
    margin: 0 0 20px;
    flex: 1;
  }

  .cap-card-resolves {
    background: #F8F9FB;
    border-radius: 10px;
    padding: 16px 18px;
    margin-bottom: 20px;
    border-left: 3px solid #2F80FF;
  }

  .cap-card-resolves-label {
    display: block;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: #2F80FF;
    margin-bottom: 6px;
  }

  .cap-card-resolves-text {
    font-size: 0.8rem;
    line-height: 1.6;
    color: #3A4050;
    margin: 0;
  }

  .cap-card-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .cap-card-item {
    font-size: 0.82rem;
    color: #3A4050;
    padding-left: 16px;
    position: relative;
    line-height: 1.5;
  }

  .cap-card-item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 8px;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #2F80FF;
    opacity: 0.4;
  }

  @media (max-width: 1024px) {
    .capacidades-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .capacidades-grid { grid-template-columns: 1fr; }
    .capacidades-title { font-size: 1.4rem; }
    .capacidades-subtitle { display: none; }
    .cap-card { padding: 28px 24px; }
  }
</style>
