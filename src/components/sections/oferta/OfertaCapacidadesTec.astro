---
// ============================================
// SABERO Consulting - Capacidades tecnológicas
// Bloque 3: Capacidades tecnológicas + Modelos + Innovación (3 cards)
// ============================================
import { getOfertaData } from '../../../data/oferta';

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const content = getOfertaData(locale as any);
const { capacidades } = content;

// Last 3 items: Capacidades tecnológicas, Modelos de colaboración, Innovación
const items = capacidades.items.slice(2);
---

<section class="oferta-cap-tec" id="capacidades-tecnologicas">
  <div class="container">
    <div class="captec-header">
      <h3 class="captec-title">
        <span class="title-blue">Capacidades</span>
        <span class="title-sep">y</span>
        <span class="title-red">tecnológicas</span>
      </h3>
      <p class="captec-subtitle">Cómo lo hacemos</p>
    </div>

    <div class="captec-grid">
      {items.map((item, i) => (
        <article class="captec-card" id={item.id}>
          <h4 class="captec-card-title">{item.title}</h4>
          <p class="captec-card-summary">{item.summary}</p>
          <div class="captec-card-resolves">
            <span class="captec-card-resolves-label">Qué resuelve</span>
            <p class="captec-card-resolves-text">{item.resolves}</p>
          </div>
          <ul class="captec-card-list">
            {item.items.map((sub) => (
              <li class="captec-card-item">{sub}</li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .oferta-cap-tec {
    padding: 60px 0 60px;
    background: #FFFFFF;
    position: relative;
  }

  .oferta-cap-tec::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: calc(100% - 48px);
    max-width: 1200px;
    height: 1px;
    background: linear-gradient(90deg, transparent, #D0D8E4, transparent);
  }

  .captec-header {
    text-align: center;
    margin-bottom: 48px;
    padding-bottom: 24px;
    border-bottom: 1px solid #E8ECF2;
  }

  .captec-title {
    font-size: 2.2rem;
    font-weight: 800;
    margin: 0 0 8px;
    letter-spacing: -0.03em;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .title-blue {
    color: #2F80FF;
  }

  .title-sep {
    color: #5E6472;
    font-weight: 400;
    font-size: 1.4rem;
  }

  .title-red {
    color: #E53935;
  }

  .captec-subtitle {
    font-size: 0.9rem;
    color: #5E6472;
    margin: 0;
  }

  .captec-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }

  .captec-card {
    border: 1px solid #E8ECF2;
    border-top: 4px solid #2F80FF;
    border-bottom: 4px solid #E53935;
    border-radius: 16px;
    padding: 36px 32px;
    background: #FFFFFF;
    transition: all 350ms ease;
    display: flex;
    flex-direction: column;
  }

  .captec-card:hover {
    box-shadow: 0 8px 28px rgba(204, 33, 33, 0.05);
    transform: translateY(-3px);
  }

  .captec-card-title {
    font-size: 1.15rem;
    font-weight: 700;
    color: #0A1628;
    margin: 0 0 14px;
    line-height: 1.3;
  }

  .captec-card-summary {
    font-size: 0.88rem;
    line-height: 1.7;
    color: #5E6472;
    margin: 0 0 20px;
    flex: 1;
  }

  .captec-card-resolves {
    background: #F8F9FB;
    border-radius: 10px;
    padding: 16px 18px;
    margin-bottom: 20px;
    border-left: 3px solid #2F80FF;
  }

  .captec-card-resolves-label {
    display: block;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: #2F80FF;
    margin-bottom: 6px;
  }

  .captec-card-resolves-text {
    font-size: 0.8rem;
    line-height: 1.6;
    color: #3A4050;
    margin: 0;
  }

  .captec-card-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .captec-card-item {
    font-size: 0.82rem;
    color: #3A4050;
    padding-left: 16px;
    position: relative;
    line-height: 1.5;
  }

  .captec-card-item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 8px;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #2F80FF;
    opacity: 0.4;
  }

  @media (max-width: 1024px) {
    .captec-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .captec-grid { grid-template-columns: 1fr; }
    .captec-title { font-size: 1.4rem; }
    .captec-subtitle { display: none; }
    .captec-card { padding: 28px 24px; }
  }
</style>
