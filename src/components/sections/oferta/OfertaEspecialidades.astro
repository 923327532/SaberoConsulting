---
// ============================================
// SABERO Consulting - Especialidades Carousel
// Carrusel automático con tarjetas flip (giratorias)
// Front: título + descripción (bordes azul/rojo, fondo crema)
// Back: scope + resolves + CTA
// ============================================
import { getOfertaData } from '../../../data/oferta';

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const content = getOfertaData(locale as any);
const { especialidades } = content;
const items = especialidades.items;
---

<section class="especialidades" id="especialidades">
  <div class="container">
    <div class="especialidades-header">
      <h3 class="especialidades-title">
        <span class="title-main">Especialidades</span>
      </h3>
    </div>

    <div class="carousel-wrapper">
      <div class="carousel-track" id="especialidades-track">
        {items.map((item, index) => (
          <article class="flip-card" id={item.id}>
            <div class="flip-card-inner">
              <!-- FRONT -->
              <div class="flip-card-front">
                <div class="flip-card-front-content">
                  <div class="flip-card-icon-wrap">
                    {index === 0 && (
                      <svg class="flip-card-icon" width="84" height="84" viewBox="0 0 84 84" fill="none">
                        <rect x="2" y="2" width="80" height="80" rx="16" stroke="url(#ig0)" stroke-width="3"/>
                        <rect x="18" y="22" width="20" height="24" rx="3" stroke="url(#ig0)" stroke-width="2.5" fill="none"/>
                        <rect x="46" y="22" width="20" height="24" rx="3" stroke="url(#ig0)" stroke-width="2.5" fill="none"/>
                        <path d="M18 52h48v10H18z" stroke="url(#ig0)" stroke-width="2" fill="none" rx="2"/>
                        <path d="M38 46v10M46 46v10" stroke="url(#ig0)" stroke-width="2" stroke-linecap="round"/>
                        <defs><linearGradient id="ig0" x1="0" y1="0" x2="84" y2="84"><stop offset="0%" stop-color="#2F80FF"/><stop offset="50%" stop-color="#0B2F7D"/><stop offset="100%" stop-color="#E53935"/></linearGradient></defs>
                      </svg>
                    )}
                    {index === 1 && (
                      <svg class="flip-card-icon" width="84" height="84" viewBox="0 0 84 84" fill="none">
                        <rect x="2" y="2" width="80" height="80" rx="16" stroke="url(#ig1)" stroke-width="3"/>
                        <circle cx="42" cy="30" r="10" stroke="url(#ig1)" stroke-width="2.5" fill="none"/>
                        <path d="M22 60c0-11.046 8.954-20 20-20s20 8.954 20 20" stroke="url(#ig1)" stroke-width="2.5" stroke-linecap="round" fill="none"/>
                        <path d="M52 18l4 4 8-8" stroke="url(#ig1)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                        <defs><linearGradient id="ig1" x1="0" y1="0" x2="84" y2="84"><stop offset="0%" stop-color="#2F80FF"/><stop offset="50%" stop-color="#0B2F7D"/><stop offset="100%" stop-color="#E53935"/></linearGradient></defs>
                      </svg>
                    )}
                    {index === 2 && (
                      <svg class="flip-card-icon" width="84" height="84" viewBox="0 0 84 84" fill="none">
                        <rect x="2" y="2" width="80" height="80" rx="16" stroke="url(#ig2)" stroke-width="3"/>
                        <circle cx="42" cy="30" r="10" stroke="url(#ig2)" stroke-width="2.5" fill="none"/>
                        <path d="M22 60c0-11.046 8.954-20 20-20s20 8.954 20 20" stroke="url(#ig2)" stroke-width="2.5" stroke-linecap="round" fill="none"/>
                        <path d="M30 38l4-4 8 8" stroke="url(#ig2)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                        <path d="M56 38l-4-4-8 8" stroke="url(#ig2)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                        <defs><linearGradient id="ig2" x1="0" y1="0" x2="84" y2="84"><stop offset="0%" stop-color="#2F80FF"/><stop offset="50%" stop-color="#0B2F7D"/><stop offset="100%" stop-color="#E53935"/></linearGradient></defs>
                      </svg>
                    )}
                    {index === 3 && (
                      <svg class="flip-card-icon" width="84" height="84" viewBox="0 0 84 84" fill="none">
                        <rect x="2" y="2" width="80" height="80" rx="16" stroke="url(#ig3)" stroke-width="3"/>
                        <path d="M22 30h40v32H22z" stroke="url(#ig3)" stroke-width="2.5" fill="none" rx="4"/>
                        <path d="M30 30V22a6 6 0 0112 0v8" stroke="url(#ig3)" stroke-width="2.5" stroke-linecap="round" fill="none"/>
                        <path d="M42 30V22a6 6 0 0112 0v8" stroke="url(#ig3)" stroke-width="2.5" stroke-linecap="round" fill="none"/>
                        <path d="M34 44l6 6 10-10" stroke="url(#ig3)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                        <defs><linearGradient id="ig3" x1="0" y1="0" x2="84" y2="84"><stop offset="0%" stop-color="#2F80FF"/><stop offset="50%" stop-color="#0B2F7D"/><stop offset="100%" stop-color="#E53935"/></linearGradient></defs>
                      </svg>
                    )}
                    {index === 4 && (
                      <svg class="flip-card-icon" width="84" height="84" viewBox="0 0 84 84" fill="none">
                        <rect x="2" y="2" width="80" height="80" rx="16" stroke="url(#ig4)" stroke-width="3"/>
                        <circle cx="42" cy="30" r="10" stroke="url(#ig4)" stroke-width="2.5" fill="none"/>
                        <path d="M22 60c0-11.046 8.954-20 20-20s20 8.954 20 20" stroke="url(#ig4)" stroke-width="2.5" stroke-linecap="round" fill="none"/>
                        <path d="M36 44l-4 4 4 4" stroke="url(#ig4)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                        <path d="M48 44l4 4-4 4" stroke="url(#ig4)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                        <defs><linearGradient id="ig4" x1="0" y1="0" x2="84" y2="84"><stop offset="0%" stop-color="#2F80FF"/><stop offset="50%" stop-color="#0B2F7D"/><stop offset="100%" stop-color="#E53935"/></linearGradient></defs>
                      </svg>
                    )}
                    {index === 5 && (
                      <svg class="flip-card-icon" width="84" height="84" viewBox="0 0 84 84" fill="none">
                        <rect x="2" y="2" width="80" height="80" rx="16" stroke="url(#ig5)" stroke-width="3"/>
                        <circle cx="42" cy="30" r="10" stroke="url(#ig5)" stroke-width="2.5" fill="none"/>
                        <path d="M22 60c0-11.046 8.954-20 20-20s20 8.954 20 20" stroke="url(#ig5)" stroke-width="2.5" stroke-linecap="round" fill="none"/>
                        <path d="M36 48l2 2 4-4" stroke="url(#ig5)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                        <path d="M52 22l4 4 8-8" stroke="url(#ig5)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                        <defs><linearGradient id="ig5" x1="0" y1="0" x2="84" y2="84"><stop offset="0%" stop-color="#2F80FF"/><stop offset="50%" stop-color="#0B2F7D"/><stop offset="100%" stop-color="#E53935"/></linearGradient></defs>
                      </svg>
                    )}
                  </div>
                  <h4 class="flip-card-title">{item.title}</h4>
                  <p class="flip-card-desc">{item.description}</p>
                </div>
                <div class="flip-card-hint">
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <path d="M8 3v10M3 8h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                  </svg>
                  <span>Ver más</span>
                </div>
              </div>
              <!-- BACK -->
              <div class="flip-card-back">
                <div class="flip-card-back-content">
                  <div class="flip-card-scope">
                    <span class="flip-card-label">Enfoque práctico</span>
                    <ul class="flip-card-scope-list">
                      {item.scope.map((s) => (
                        <li class="flip-card-scope-item">{s}</li>
                      ))}
                    </ul>
                  </div>
                  <div class="flip-card-result">
                    <span class="flip-card-label flip-card-label--red">Resultado que aporta</span>
                    <p class="flip-card-result-text">{item.resolves}</p>
                  </div>
                  {item.cta && (
                    <a href={item.ctaHref || '#'} class="flip-card-cta">
                      {item.cta}
                      <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                        <path d="M2 6h8M6 2l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </a>
                  )}
                </div>
                <div class="flip-card-hint flip-card-hint--back">
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <path d="M3 8h10M8 3l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  <span>Volver</span>
                </div>
              </div>
            </div>
          </article>
        ))}
      </div>

      <!-- Navigation dots -->
      <div class="carousel-dots" id="especialidades-dots">
        {items.map((_, index) => (
          <button class="carousel-dot" data-index={index} aria-label={`Ir a especialidad ${index + 1}`}></button>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  // ============================================
  // Carousel + Flip logic
  // ============================================
  const track = document.getElementById('especialidades-track')!;
  const dots = document.querySelectorAll('.carousel-dot');
  const cards = track.querySelectorAll('.flip-card');
  if (!cards.length) throw new Error('Missing carousel elements');

  let currentIndex = 0;
  let autoPlayInterval: ReturnType<typeof setInterval> | null = null;
  const AUTO_PLAY_MS = 5000;

  function getVisibleCount(): number {
    const w = window.innerWidth;
    if (w < 640) return 1;
    if (w < 1024) return 2;
    if (w < 1280) return 3;
    return 4;
  }

  function updateCarousel() {
    const visible = getVisibleCount();
    const maxIndex = Math.max(0, cards.length - visible);
    if (currentIndex > maxIndex) currentIndex = maxIndex;
    const offset = -(currentIndex * (100 / visible));
    track.style.transform = `translateX(${offset}%)`;

    dots.forEach((dot, i) => {
      dot.classList.toggle('active', i === currentIndex);
    });
  }

  function goTo(index: number) {
    const visible = getVisibleCount();
    const maxIndex = Math.max(0, cards.length - visible);
    currentIndex = Math.min(Math.max(0, index), maxIndex);
    updateCarousel();
    resetAutoPlay();
  }

  function goNext() {
    const visible = getVisibleCount();
    const maxIndex = Math.max(0, cards.length - visible);
    if (currentIndex >= maxIndex) {
      currentIndex = 0;
    } else {
      currentIndex++;
    }
    updateCarousel();
  }

  function startAutoPlay() {
    stopAutoPlay();
    autoPlayInterval = setInterval(goNext, AUTO_PLAY_MS);
  }

  function stopAutoPlay() {
    if (autoPlayInterval) {
      clearInterval(autoPlayInterval);
      autoPlayInterval = null;
    }
  }

  function resetAutoPlay() {
    startAutoPlay();
  }

  // Flip cards on click
  cards.forEach((card) => {
    card.addEventListener('click', (e) => {
      // Don't flip if clicking a link
      if ((e.target as HTMLElement).closest('a')) return;
      card.classList.toggle('flipped');
    });
  });

  // Dot navigation
  dots.forEach((dot) => {
    dot.addEventListener('click', () => {
      const index = parseInt(dot.getAttribute('data-index') || '0', 10);
      goTo(index);
    });
  });

  // Resize handler
  let resizeTimeout: ReturnType<typeof setTimeout> | null = null;
  window.addEventListener('resize', () => {
    if (resizeTimeout) clearTimeout(resizeTimeout);
    resizeTimeout = setTimeout(updateCarousel, 150);
  });

  // Pause on hover
  track.addEventListener('mouseenter', stopAutoPlay);
  track.addEventListener('mouseleave', startAutoPlay);

  // Touch support
  let touchStartX = 0;
  let touchEndX = 0;
  track.addEventListener('touchstart', (e) => {
    touchStartX = e.changedTouches[0].screenX;
  }, { passive: true });
  track.addEventListener('touchend', (e) => {
    touchEndX = e.changedTouches[0].screenX;
    const diff = touchStartX - touchEndX;
    if (Math.abs(diff) > 50) {
      if (diff > 0) goNext();
      else {
        const visible = getVisibleCount();
        const maxIndex = Math.max(0, cards.length - visible);
        if (currentIndex <= 0) {
          currentIndex = maxIndex;
        } else {
          currentIndex--;
        }
        updateCarousel();
        resetAutoPlay();
      }
    }
  }, { passive: true });

  // Init
  updateCarousel();
  startAutoPlay();
</script>

<style>
  /* ============================================
     Section layout
     ============================================ */
  .especialidades {
    padding: 60px 0 60px;
    background: #F8F9FB;
    position: relative;
    overflow: hidden;
  }

  .especialidades-header {
    text-align: center;
    margin-bottom: 48px;
    padding-bottom: 24px;
    border-bottom: 1px solid #E8ECF2;
  }

  .especialidades-title {
    font-size: 2.2rem;
    font-weight: 800;
    margin: 0;
    letter-spacing: -0.03em;
  }

  .title-main {
    background: linear-gradient(135deg, #2F80FF 0%, #0B2F7D 40%, #E53935 70%, #C62828 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* ============================================
     Carousel
     ============================================ */
  .carousel-wrapper {
    position: relative;
    overflow: hidden;
  }

  .carousel-track {
    display: flex;
    gap: 20px;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    will-change: transform;
  }

  /* ============================================
     Flip Card
     ============================================ */
  .flip-card {
    flex: 0 0 calc(25% - 15px);
    min-width: 0;
    perspective: 1200px;
    height: 420px;
    cursor: pointer;
  }

  .flip-card-inner {
    position: relative;
    width: 100%;
    height: 100%;
    transition: transform 0.7s cubic-bezier(0.4, 0, 0.2, 1);
    transform-style: preserve-3d;
  }

  .flip-card.flipped .flip-card-inner {
    transform: rotateY(180deg);
  }

  /* ---- Front & Back shared ---- */
  .flip-card-front,
  .flip-card-back {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    border-radius: 16px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  /* ---- FRONT ---- */
  .flip-card-front {
    background: #FFFFFF; /* white */
    border: 1px solid #E8ECF2;
    border-top: 4px solid #2F80FF; /* blue top edge */
    border-bottom: 4px solid #E53935; /* red bottom edge */
    padding: 28px 24px 20px;
  }

  .flip-card-front-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .flip-card-icon-wrap {
    display: flex;
    justify-content: center;
    align-items: center;
    margin-bottom: 20px;
  }

  .flip-card-icon {
    width: 84px;
    height: 84px;
    flex-shrink: 0;
  }

  .flip-card-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: #0A1628;
    margin: 0 0 12px;
    line-height: 1.3;
  }

  .flip-card-desc {
    font-size: 0.82rem;
    line-height: 1.7;
    color: #5E6472;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .flip-card-hint {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.72rem;
    font-weight: 600;
    color: #2F80FF;
    margin-top: 16px;
    padding-top: 12px;
    border-top: 1px solid #E8ECF2;
    opacity: 0.7;
    transition: opacity 200ms;
  }

  .flip-card:hover .flip-card-hint {
    opacity: 1;
  }

  /* ---- BACK ---- */
  .flip-card-back {
    background: #FFFDF5; /* cream */
    border: 1px solid #E8ECF2;
    border-top: 4px solid #E53935; /* red top edge */
    border-bottom: 4px solid #2F80FF; /* blue bottom edge */
    padding: 28px 24px 20px;
    transform: rotateY(180deg);
  }

  .flip-card-back-content {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .flip-card-label {
    display: block;
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: #2F80FF;
    margin-bottom: 8px;
  }

  .flip-card-label--red {
    color: #E53935;
  }

  .flip-card-scope {
    background: #F8F9FB;
    border-radius: 10px;
    padding: 14px 16px;
    margin-bottom: 14px;
  }

  .flip-card-scope-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .flip-card-scope-item {
    font-size: 0.75rem;
    color: #3A4050;
    padding-left: 12px;
    position: relative;
    line-height: 1.5;
  }

  .flip-card-scope-item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 7px;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: #2F80FF;
    opacity: 0.4;
  }

  .flip-card-result {
    margin-bottom: 12px;
  }

  .flip-card-result-text {
    font-size: 0.78rem;
    line-height: 1.6;
    color: #3A4050;
    margin: 0;
  }

  .flip-card-cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.78rem;
    font-weight: 600;
    color: #0B2F7D;
    text-decoration: none;
    padding-top: 12px;
    border-top: 1px solid #E8ECF2;
    transition: all 200ms ease;
    margin-top: auto;
  }

  .flip-card-cta:hover {
    color: #2F80FF;
    gap: 10px;
  }

  .flip-card-cta svg {
    transition: transform 200ms ease;
  }

  .flip-card-cta:hover svg {
    transform: translateX(3px);
  }

  .flip-card-hint--back {
    color: #E53935;
    border-top-color: #E8ECF2;
  }

  /* ============================================
     Dots navigation
     ============================================ */
  .carousel-dots {
    display: flex;
    justify-content: center;
    gap: 10px;
    margin-top: 32px;
  }

  .carousel-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 2px solid #C8D0DC;
    background: transparent;
    cursor: pointer;
    padding: 0;
    transition: all 300ms ease;
  }

  .carousel-dot.active {
    background: #2F80FF;
    border-color: #2F80FF;
    width: 28px;
    border-radius: 5px;
  }

  .carousel-dot:hover {
    border-color: #2F80FF;
  }

  /* ============================================
     Responsive
     ============================================ */
  @media (max-width: 1280px) {
    .flip-card { flex: 0 0 calc(33.333% - 14px); height: 400px; }
  }

  @media (max-width: 1024px) {
    .flip-card { flex: 0 0 calc(50% - 10px); height: 380px; }
  }

  @media (max-width: 640px) {
    .flip-card { flex: 0 0 100%; height: 360px; }
    .especialidades-title { font-size: 1.4rem; }
    .especialidades { padding: 60px 0 60px; }
  }
</style>
