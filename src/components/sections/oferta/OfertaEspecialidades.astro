---
// ============================================
// SABERO Consulting - Especialidades
// Bloque 3: Especialidades concretas premium
// Cada card: título, descripción, enfoque práctico, resultado
// ============================================
import { ofertaContent } from '../../../data/home/oferta';

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const content = ofertaContent[locale] || ofertaContent.es;
const { especialidades } = content;
---

<section class="especialidades">
  <div class="container">
    <div class="especialidades-header">
      <span class="especialidades-number">02</span>
      <h3 class="especialidades-title">{especialidades.title}</h3>
      <p class="especialidades-subtitle">{especialidades.subtitle}</p>
    </div>

    <div class="especialidades-grid">
      {especialidades.items.map((item) => (
        <article class="esp-card" id={item.id}>
          <div class="esp-card-top">
            <h4 class="esp-card-title">{item.title}</h4>
          </div>
          <p class="esp-card-desc">{item.description}</p>
          <div class="esp-card-scope">
            <span class="esp-card-scope-label">Enfoque práctico</span>
            <ul class="esp-card-scope-list">
              {item.scope.map((s) => (
                <li class="esp-card-scope-item">{s}</li>
              ))}
            </ul>
          </div>
          <div class="esp-card-result">
            <span class="esp-card-result-label">Resultado que aporta</span>
            <p class="esp-card-result-text">{item.resolves}</p>
          </div>
          {item.cta && (
            <a href={item.ctaHref || '#'} class="esp-card-cta">
              {item.cta}
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                <path d="M2 6h8M6 2l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          )}
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .especialidades {
    padding: 120px 0 140px;
    background: #F8F9FB;
    position: relative;
  }

  .especialidades::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: calc(100% - 48px);
    max-width: 1200px;
    height: 1px;
    background: linear-gradient(90deg, transparent, #D0D8E4, transparent);
  }

  .especialidades-header {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 48px;
    padding-bottom: 24px;
    border-bottom: 1px solid #E8ECF2;
  }

  .especialidades-number {
    font-size: 0.7rem;
    font-weight: 700;
    color: #E53935;
    letter-spacing: 2px;
    background: #FDF0F0;
    padding: 4px 12px;
    border-radius: 4px;
  }

  .especialidades-title {
    font-size: 1.8rem;
    font-weight: 700;
    color: #0A1628;
    margin: 0;
    letter-spacing: -0.02em;
  }

  .especialidades-subtitle {
    font-size: 0.9rem;
    color: #5E6472;
    margin: 0 0 0 auto;
  }

  .especialidades-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }

  .esp-card {
    background: #FFFFFF;
    border: 1px solid #E8ECF2;
    border-radius: 16px;
    padding: 32px 28px;
    display: flex;
    flex-direction: column;
    transition: all 350ms ease;
  }

  .esp-card:hover {
    border-color: #C8D0DC;
    box-shadow: 0 8px 28px rgba(0,0,0,0.05);
    transform: translateY(-3px);
  }

  .esp-card-top {
    margin-bottom: 14px;
  }

  .esp-card-title {
    font-size: 1rem;
    font-weight: 700;
    color: #0A1628;
    margin: 0;
    line-height: 1.3;
  }

  .esp-card-desc {
    font-size: 0.82rem;
    line-height: 1.7;
    color: #5E6472;
    margin: 0 0 20px;
    flex: 1;
  }

  .esp-card-scope {
    background: #F8F9FB;
    border-radius: 10px;
    padding: 14px 16px;
    margin-bottom: 16px;
  }

  .esp-card-scope-label {
    display: block;
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: #2F80FF;
    margin-bottom: 8px;
  }

  .esp-card-scope-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .esp-card-scope-item {
    font-size: 0.75rem;
    color: #3A4050;
    padding-left: 12px;
    position: relative;
    line-height: 1.5;
  }

  .esp-card-scope-item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 7px;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: #2F80FF;
    opacity: 0.4;
  }

  .esp-card-result {
    margin-bottom: 16px;
  }

  .esp-card-result-label {
    display: block;
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: #E53935;
    margin-bottom: 6px;
  }

  .esp-card-result-text {
    font-size: 0.78rem;
    line-height: 1.6;
    color: #3A4050;
    margin: 0;
  }

  .esp-card-cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.78rem;
    font-weight: 600;
    color: #0B2F7D;
    text-decoration: none;
    padding-top: 14px;
    border-top: 1px solid #E8ECF2;
    transition: all 200ms ease;
    margin-top: auto;
  }

  .esp-card-cta:hover {
    color: #2F80FF;
    gap: 10px;
  }

  .esp-card-cta svg {
    transition: transform 200ms ease;
  }

  .esp-card-cta:hover svg {
    transform: translateX(3px);
  }

  @media (max-width: 1100px) {
    .especialidades-grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media (max-width: 768px) {
    .especialidades-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .especialidades-grid { grid-template-columns: 1fr; }
    .especialidades-title { font-size: 1.4rem; }
    .especialidades-subtitle { display: none; }
    .esp-card { padding: 24px; }
  }
</style>
