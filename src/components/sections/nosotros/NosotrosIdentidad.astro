---
// ============================================
// SABERO Consulting - Nosotros Section 2: Identidad
// ============================================
import type { NosotrosData } from '../../../data/nosotros/types';

interface Props {
  content: NosotrosData;
}

const { content } = Astro.props;
---

<section class="nosotros-identidad" id="identidad-trayectoria" aria-label="Identidad y trayectoria">
  <div class="container">
    <div class="nosotros-identidad-header">
      <span class="nosotros-identidad-number">01</span>
      <h3 class="nosotros-identidad-title">Identidad y trayectoria</h3>
    </div>

    <div class="nosotros-identidad-grid">
      {content.identidad.map((bloque) => (
        <article class="identidad-bloque">
          <h4 class="identidad-bloque-title">{bloque.titulo}</h4>
          <p class="identidad-bloque-texto">{bloque.contenido}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .nosotros-identidad {
    background: #FFFFFF;
    padding: 0 0 100px;
  }

  .nosotros-identidad-header {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 48px;
    padding-bottom: 20px;
    border-bottom: 1px solid #E8ECF2;
  }

  .nosotros-identidad-number {
    font-size: 0.7rem;
    font-weight: 700;
    color: #2F80FF;
    letter-spacing: 2px;
    background: #F0F5FF;
    padding: 4px 12px;
    border-radius: 4px;
    flex-shrink: 0;
  }

  .nosotros-identidad-title {
    font-size: 1.6rem;
    font-weight: 700;
    color: #0A1628;
    margin: 0;
    letter-spacing: -0.02em;
  }

  .nosotros-identidad-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 32px;
  }

  .identidad-bloque {
    padding: 32px;
    background: #F8F9FB;
    border-radius: 14px;
    border: 1px solid #E8ECF2;
    transition: all 300ms ease;
  }

  .identidad-bloque:hover {
    border-color: #C8D0DC;
    box-shadow: 0 8px 24px rgba(0,0,0,0.03);
  }

  .identidad-bloque-title {
    font-size: 1rem;
    font-weight: 700;
    color: #0A1628;
    margin: 0 0 12px;
    padding-bottom: 12px;
    border-bottom: 2px solid #2F80FF;
    display: inline-block;
  }

  .identidad-bloque-texto {
    font-size: 0.85rem;
    line-height: 1.8;
    color: #5E6472;
    margin: 0;
  }

  @media (max-width: 1024px) {
    .nosotros-identidad-grid { grid-template-columns: 1fr; gap: 20px; }
  }

  @media (max-width: 640px) {
    .nosotros-identidad { padding: 0 0 60px; }
    .identidad-bloque { padding: 24px 20px; }
  }
</style>
