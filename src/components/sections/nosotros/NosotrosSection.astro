---
// ============================================
// SABERO Consulting - Nosotros Section Orchestrator
// 5 secciones claras en la home
// ============================================
import { getNosotrosData } from '../../../data/nosotros';
import type { SupportedLocale } from '../../../i18n/utils/types';
import NosotrosIntro from './NosotrosIntro.astro';
import NosotrosIdentidad from './NosotrosIdentidad.astro';
import NosotrosEnfoque from './NosotrosEnfoque.astro';
import NosotrosCultura from './NosotrosCultura.astro';
import NosotrosCTA from './NosotrosCTA.astro';

interface Props {
  locale: SupportedLocale;
}

const { locale } = Astro.props;
const content = getNosotrosData(locale);
---

<section class="nosotros-section" aria-label={content.intro.titulo}>
  <!-- Section 1: Intro general -->
  <NosotrosIntro content={content} />

  <!-- Section 2: Identidad y trayectoria -->
  <NosotrosIdentidad content={content} />

  <!-- Section 3: Enfoque de trabajo -->
  <NosotrosEnfoque content={content} />

  <!-- Section 4: Cultura, valores y diferenciadores -->
  <NosotrosCultura content={content} />

  <!-- Section 5: CTA final -->
  <NosotrosCTA content={content} />
</section>

<style>
  .nosotros-section {
    background: #FFFFFF;
    padding: 0;
  }
</style>
