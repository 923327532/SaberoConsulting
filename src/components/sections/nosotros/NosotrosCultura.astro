---
// ============================================
// SABERO Consulting - Nosotros Section 4: Cultura
// ============================================
import type { NosotrosData } from '../../../data/nosotros/types';

interface Props {
  content: NosotrosData;
}

const { content } = Astro.props;
---

<section class="nosotros-cultura" id="cultura-valores" aria-label="Cultura, valores y diferenciadores">
  <div class="container">
    <div class="nosotros-cultura-header">
      <span class="nosotros-cultura-number">03</span>
      <h3 class="nosotros-cultura-title">Cultura, valores y diferenciadores</h3>
    </div>

    <div class="nosotros-cultura-grid">
      {content.cultura.map((bloque) => (
        <article class="cultura-bloque">
          <h4 class="cultura-bloque-title">{bloque.titulo}</h4>
          <p class="cultura-bloque-texto">{bloque.contenido}</p>
          {bloque.items && bloque.items.length > 0 && (
            <ul class="cultura-bloque-list">
              {bloque.items.map((item) => (
                <li class="cultura-bloque-item">{item}</li>
              ))}
            </ul>
          )}
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .nosotros-cultura {
    background: #FFFFFF;
    padding: 100px 0;
  }

  .nosotros-cultura-header {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 48px;
    padding-bottom: 20px;
    border-bottom: 1px solid #E8ECF2;
  }

  .nosotros-cultura-number {
    font-size: 0.7rem;
    font-weight: 700;
    color: #2F80FF;
    letter-spacing: 2px;
    background: #F0F5FF;
    padding: 4px 12px;
    border-radius: 4px;
    flex-shrink: 0;
  }

  .nosotros-cultura-title {
    font-size: 1.6rem;
    font-weight: 700;
    color: #0A1628;
    margin: 0;
    letter-spacing: -0.02em;
  }

  .nosotros-cultura-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .cultura-bloque {
    background: #F8F9FB;
    border: 1px solid #E8ECF2;
    border-radius: 14px;
    padding: 36px 28px;
    transition: all 300ms ease;
  }

  .cultura-bloque:hover {
    border-color: #C8D0DC;
    box-shadow: 0 8px 24px rgba(0,0,0,0.03);
  }

  .cultura-bloque-title {
    font-size: 1rem;
    font-weight: 700;
    color: #0A1628;
    margin: 0 0 14px;
    padding-bottom: 12px;
    border-bottom: 2px solid #2F80FF;
    display: inline-block;
  }

  .cultura-bloque-texto {
    font-size: 0.82rem;
    line-height: 1.8;
    color: #5E6472;
    margin: 0 0 16px;
  }

  .cultura-bloque-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .cultura-bloque-item {
    font-size: 0.78rem;
    line-height: 1.6;
    color: #3A4050;
    padding-left: 16px;
    position: relative;
  }

  .cultura-bloque-item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 7px;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #2F80FF;
    opacity: 0.35;
  }

  @media (max-width: 1024px) {
    .nosotros-cultura-grid { grid-template-columns: 1fr; gap: 20px; }
  }

  @media (max-width: 640px) {
    .nosotros-cultura { padding: 60px 0; }
    .cultura-bloque { padding: 24px 20px; }
  }
</style>
