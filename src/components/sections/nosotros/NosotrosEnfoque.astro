---
// ============================================
// SABERO Consulting - Nosotros Section 3: Enfoque
// ============================================
import type { NosotrosData } from '../../../data/nosotros/types';

interface Props {
  content: NosotrosData;
}

const { content } = Astro.props;
---

<section class="nosotros-enfoque" id="enfoque-trabajo" aria-label="Enfoque de trabajo">
  <div class="container">
    <div class="nosotros-enfoque-header">
      <span class="nosotros-enfoque-number">02</span>
      <h3 class="nosotros-enfoque-title">Enfoque de trabajo</h3>
    </div>

    <div class="nosotros-enfoque-grid">
      {content.enfoque.map((bloque) => (
        <article class="enfoque-bloque">
          <h4 class="enfoque-bloque-title">{bloque.titulo}</h4>
          <p class="enfoque-bloque-texto">{bloque.contenido}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .nosotros-enfoque {
    background: #F8F9FB;
    padding: 100px 0;
  }

  .nosotros-enfoque-header {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 48px;
    padding-bottom: 20px;
    border-bottom: 1px solid #D0D8E4;
  }

  .nosotros-enfoque-number {
    font-size: 0.7rem;
    font-weight: 700;
    color: #2F80FF;
    letter-spacing: 2px;
    background: #F0F5FF;
    padding: 4px 12px;
    border-radius: 4px;
    flex-shrink: 0;
  }

  .nosotros-enfoque-title {
    font-size: 1.6rem;
    font-weight: 700;
    color: #0A1628;
    margin: 0;
    letter-spacing: -0.02em;
  }

  .nosotros-enfoque-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .enfoque-bloque {
    background: #FFFFFF;
    border: 1px solid #E8ECF2;
    border-radius: 14px;
    padding: 32px 28px;
    transition: all 300ms ease;
  }

  .enfoque-bloque:hover {
    border-color: #C8D0DC;
    box-shadow: 0 8px 24px rgba(0,0,0,0.03);
  }

  .enfoque-bloque-title {
    font-size: 0.95rem;
    font-weight: 700;
    color: #0A1628;
    margin: 0 0 12px;
    padding-bottom: 10px;
    border-bottom: 2px solid #2F80FF;
    display: inline-block;
  }

  .enfoque-bloque-texto {
    font-size: 0.82rem;
    line-height: 1.8;
    color: #5E6472;
    margin: 0;
  }

  @media (max-width: 1024px) {
    .nosotros-enfoque-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .nosotros-enfoque { padding: 60px 0; }
    .nosotros-enfoque-grid { grid-template-columns: 1fr; }
    .enfoque-bloque { padding: 24px 20px; }
  }
</style>
