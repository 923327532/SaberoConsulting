---
// ============================================
// SABERO Consulting - Nosotros Section 1: Intro
// ============================================
import type { NosotrosData } from '../../../data/nosotros/types';

interface Props {
  content: NosotrosData;
}

const { content } = Astro.props;
---

<section class="nosotros-intro" id="nosotros" aria-label={content.intro.titulo}>
  <div class="container">
    <div class="nosotros-intro-grid">
      <div class="nosotros-intro-left">
        <span class="nosotros-intro-eyebrow">Quiénes somos</span>
        <h2 class="nosotros-intro-title">{content.intro.titulo}</h2>
      </div>
      <div class="nosotros-intro-right">
        <p class="nosotros-intro-texto">{content.intro.texto}</p>
        <p class="nosotros-intro-micro">{content.intro.microcopy}</p>
      </div>
    </div>
  </div>
</section>

<style>
  .nosotros-intro {
    background: #FFFFFF;
    padding: 120px 0 80px;
  }

  .nosotros-intro-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 60px;
    align-items: start;
  }

  .nosotros-intro-eyebrow {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: #2F80FF;
    background: #F0F5FF;
    padding: 4px 12px;
    border-radius: 4px;
    margin-bottom: 20px;
  }

  .nosotros-intro-title {
    font-size: clamp(2.2rem, 4vw, 3.5rem);
    font-weight: 800;
    color: #0A1628;
    margin: 0;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  .nosotros-intro-texto {
    font-size: 1.05rem;
    line-height: 1.8;
    color: #3A4050;
    margin: 0 0 16px;
    font-weight: 500;
  }

  .nosotros-intro-micro {
    font-size: 0.85rem;
    line-height: 1.7;
    color: #7A8290;
    margin: 0;
    padding: 16px 20px;
    background: #F8F9FB;
    border-left: 3px solid #2F80FF;
    border-radius: 0 8px 8px 0;
  }

  @media (max-width: 1024px) {
    .nosotros-intro-grid { grid-template-columns: 1fr; gap: 24px; }
  }

  @media (max-width: 640px) {
    .nosotros-intro { padding: 80px 0 48px; }
  }
</style>
