---
// ============================================
// SABERO Consulting - Nosotros Section 5: CTA Final
// ============================================
import type { NosotrosData } from '../../../data/nosotros/types';

interface Props {
  content: NosotrosData;
}

const { content } = Astro.props;
const { cta } = content;
---

<section class="nosotros-cta-final" aria-label="Próximos pasos">
  <div class="container">
    <div class="nosotros-cta-final-card">
      <div class="nosotros-cta-final-content">
        <p class="nosotros-cta-final-frase">{cta.frase}</p>
        <div class="nosotros-cta-final-actions">
          <a href={cta.ctaPrincipalHref} class="nosotros-cta-final-primary">
            {cta.ctaPrincipal}
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M2 7h10M7 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href={cta.ctaSecundarioHref} class="nosotros-cta-final-secondary">
            {cta.ctaSecundario}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .nosotros-cta-final {
    background: #F8F9FB;
    padding: 80px 0 120px;
  }

  .nosotros-cta-final-card {
    background: linear-gradient(135deg, #0A1628 0%, #1A2A48 100%);
    border-radius: 20px;
    padding: 60px;
    position: relative;
    overflow: hidden;
  }

  .nosotros-cta-final-card::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(47, 128, 255, 0.08) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
  }

  .nosotros-cta-final-content {
    position: relative;
    z-index: 1;
    max-width: 700px;
  }

  .nosotros-cta-final-frase {
    font-size: 1.15rem;
    line-height: 1.8;
    color: #C8D0DC;
    margin: 0 0 32px;
    font-weight: 400;
  }

  .nosotros-cta-final-actions {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .nosotros-cta-final-primary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 28px;
    font-size: 0.9rem;
    font-weight: 600;
    color: #FFFFFF;
    background: #2F80FF;
    border-radius: 10px;
    text-decoration: none;
    transition: all 300ms ease;
  }

  .nosotros-cta-final-primary:hover {
    background: #1A6AE0;
    box-shadow: 0 8px 24px rgba(47, 128, 255, 0.3);
    transform: translateY(-2px);
  }

  .nosotros-cta-final-primary svg {
    transition: transform 300ms ease;
  }

  .nosotros-cta-final-primary:hover svg {
    transform: translateX(3px);
  }

  .nosotros-cta-final-secondary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 28px;
    font-size: 0.9rem;
    font-weight: 600;
    color: #C8D0DC;
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 10px;
    text-decoration: none;
    transition: all 300ms ease;
  }

  .nosotros-cta-final-secondary:hover {
    color: #FFFFFF;
    border-color: rgba(255,255,255,0.3);
    background: rgba(255,255,255,0.05);
  }

  @media (max-width: 640px) {
    .nosotros-cta-final { padding: 60px 0 80px; }
    .nosotros-cta-final-card { padding: 32px 24px; }
    .nosotros-cta-final-actions { flex-direction: column; align-items: stretch; }
    .nosotros-cta-final-primary,
    .nosotros-cta-final-secondary { justify-content: center; }
  }
</style>
