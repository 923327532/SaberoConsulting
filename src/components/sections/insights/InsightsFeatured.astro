---
import type { InsightItem } from '../../../data/insights/types';

interface Props {
  featured: InsightItem[];
}

const { featured } = Astro.props;
const primary = featured[0];
const secondary = featured.slice(1);
---

<section class="featured-section section" id="featured" aria-label="Destacados">
  <div class="container">
    <h2 class="section-title">Destacados</h2>
    <div class="featured-layout">
      <article class="featured-primary">
        <div class="featured-primary-content">
          <span class="featured-badge">{primary.category}</span>
          <h3 class="featured-primary-title">{primary.title}</h3>
          <p class="featured-primary-summary">{primary.summary}</p>
          <div class="featured-meta">
            <span class="featured-readtime">{primary.readTime}</span>
            <a href="#" class="featured-cta">{primary.cta} &rarr;</a>
          </div>
        </div>
      </article>
      <div class="featured-secondary">
        {secondary.map((item) => (
          <article class="featured-card">
            <span class="featured-badge">{item.category}</span>
            <h4 class="featured-card-title">{item.title}</h4>
            <p class="featured-card-summary">{item.summary}</p>
            <div class="featured-meta">
              <span class="featured-readtime">{item.readTime}</span>
              <a href="#" class="featured-cta">{item.cta} &rarr;</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .featured-section {
    background-color: var(--color-white);
    padding: var(--space-20) 0;
  }

  .featured-section .section-title {
    margin-bottom: var(--space-10);
  }

  .featured-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
  }

  .featured-primary {
    background: linear-gradient(135deg, var(--color-electric-blue-light) 0%, #FFF5F5 100%);
    border-radius: var(--radius-xl);
    padding: 40px;
    border: 1px solid var(--border-color);
    transition: box-shadow var(--transition-slow);
  }

  .featured-primary:hover {
    box-shadow: var(--shadow-lg);
  }

  .featured-primary-content {
    max-width: 100%;
  }

  .featured-badge {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--color-electric-blue);
    background: rgba(0, 102, 255, 0.08);
    padding: 4px 12px;
    border-radius: var(--radius-full);
    margin-bottom: 16px;
  }

  .featured-primary-title {
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 16px;
    line-height: 1.3;
  }

  .featured-primary-summary {
    font-size: var(--text-base);
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 20px;
  }

  .featured-secondary {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .featured-card {
    background: var(--color-white);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 24px;
    transition: all var(--transition-base);
  }

  .featured-card:hover {
    border-color: var(--color-gray-200);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .featured-card-title {
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 8px;
    line-height: 1.4;
  }

  .featured-card-summary {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 12px;
  }

  .featured-meta {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .featured-readtime {
    font-size: var(--text-sm);
    color: var(--text-tertiary);
  }

  .featured-cta {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-electric-blue);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .featured-cta:hover {
    color: var(--color-red);
  }

  @media (max-width: 900px) {
    .featured-layout {
      grid-template-columns: 1fr;
    }

    .featured-primary-title {
      font-size: var(--text-xl);
    }
  }

  @media (max-width: 600px) {
    .featured-section {
      padding: var(--space-12) 0;
    }

    .featured-primary {
      padding: 24px;
    }
  }
</style>
