---
import type { InsightItem } from '../../../data/insights/types';

interface Props {
  articles: InsightItem[];
  title: string;
}

const { articles, title } = Astro.props;
---

<section class="grid-section section" aria-label={title}>
  <div class="container">
    <h2 class="section-title">{title}</h2>
    <div class="articles-grid">
      {articles.map((article) => (
        <article class="article-card">
          <span class="article-badge">{article.category}</span>
          <h3 class="article-title">{article.title}</h3>
          <p class="article-summary">{article.summary}</p>
          <div class="article-footer">
            <span class="article-readtime">{article.readTime}</span>
            <a href="#" class="article-cta">{article.cta} &rarr;</a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .grid-section {
    background-color: var(--bg-secondary);
    padding: var(--space-20) 0;
  }

  .grid-section .section-title {
    margin-bottom: var(--space-10);
  }

  .articles-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .article-card {
    background: var(--color-white);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 28px;
    display: flex;
    flex-direction: column;
    transition: all var(--transition-base);
  }

  .article-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: var(--color-gray-200);
  }

  .article-badge {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--color-electric-blue);
    background: rgba(0, 102, 255, 0.06);
    padding: 3px 10px;
    border-radius: var(--radius-full);
    margin-bottom: 12px;
    align-self: flex-start;
  }

  .article-title {
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 10px;
    line-height: 1.4;
  }

  .article-summary {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 16px;
    flex: 1;
  }

  .article-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 12px;
    border-top: 1px solid var(--border-color);
  }

  .article-readtime {
    font-size: var(--text-xs);
    color: var(--text-tertiary);
  }

  .article-cta {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-electric-blue);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .article-cta:hover {
    color: var(--color-red);
  }

  @media (max-width: 900px) {
    .articles-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .grid-section {
      padding: var(--space-12) 0;
    }

    .articles-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
