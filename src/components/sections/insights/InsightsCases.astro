---
import type { InsightCase } from '../../../data/insights/types';

interface Props {
  cases: InsightCase[];
  title: string;
}

const { cases, title } = Astro.props;
---

<section class="cases-section section" aria-label={title}>
  <div class="container">
    <h2 class="section-title">{title}</h2>
    <div class="cases-list">
      {cases.map((c) => (
        <article class="case-card">
          <h3 class="case-title">{c.title}</h3>
          <div class="case-details">
            <div class="case-block">
              <span class="case-label">Problema</span>
              <p class="case-text">{c.problem}</p>
            </div>
            <div class="case-block">
              <span class="case-label">Enfoque</span>
              <p class="case-text">{c.approach}</p>
            </div>
            <div class="case-block">
              <span class="case-label">Aprendizaje</span>
              <p class="case-text">{c.lesson}</p>
            </div>
            <div class="case-block">
              <span class="case-label">Recomendacion</span>
              <p class="case-text case-recommendation">{c.recommendation}</p>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .cases-section {
    background-color: var(--bg-secondary);
    padding: var(--space-20) 0;
  }

  .cases-section .section-title {
    margin-bottom: var(--space-10);
  }

  .cases-list {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .case-card {
    background: var(--color-white);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 36px 32px;
    transition: box-shadow var(--transition-base);
  }

  .case-card:hover {
    box-shadow: var(--shadow-md);
  }

  .case-title {
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 24px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--border-color);
  }

  .case-details {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .case-block {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .case-block:last-child {
    grid-column: 1 / -1;
  }

  .case-label {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--color-red);
  }

  .case-text {
    font-size: var(--text-base);
    color: var(--text-secondary);
    line-height: 1.7;
    margin: 0;
  }

  .case-recommendation {
    color: var(--color-electric-blue);
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .case-details {
      grid-template-columns: 1fr;
    }

    .case-card {
      padding: 24px 20px;
    }
  }

  @media (max-width: 600px) {
    .cases-section {
      padding: var(--space-12) 0;
    }
  }
</style>
