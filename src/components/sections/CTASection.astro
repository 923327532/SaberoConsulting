---
interface Props {
  locale: string;
}

const { locale } = Astro.props;

const content = {
  es: {
    title: 'Listo para construir tu proximo producto digital?',
    subtitle: 'Conversemos sin compromiso. Te responderemos en menos de 24 horas.',
    cta: 'Contactanos',
  },
  en: {
    title: 'Ready to build your next digital product?',
    subtitle: "Let's talk without commitment. We'll respond within 24 hours.",
    cta: 'Contact us',
  },
  pt: {
    title: 'Pronto para construir seu proximo produto digital?',
    subtitle: 'Vamos conversar sem compromisso. Responderemos em ate 24 horas.',
    cta: 'Fale conosco',
  },
  fr: {
    title: 'Pret a construire votre prochain produit numerique?',
    subtitle: 'Parlons-en sans engagement. Nous repondrons en moins de 24 heures.',
    cta: 'Contactez-nous',
  },
}[locale] || {
  title: 'Listo para construir tu proximo producto digital?',
  subtitle: 'Conversemos sin compromiso. Te responderemos en menos de 24 horas.',
  cta: 'Contactanos',
};
---

<section class="cta section" aria-label="Call to action">
  <div class="container">
    <div class="cta-content">
      <h2 class="cta-title">{content.title}</h2>
      <p class="cta-subtitle">{content.subtitle}</p>
      <a href={locale === 'es' ? '/contacto' : `/${locale}/contacto`} class="btn btn-primary btn-lg">{content.cta}</a>
    </div>
  </div>
</section>

<style>
  .cta {
    background: linear-gradient(135deg, var(--color-deep-blue) 0%, var(--color-deep-blue-light) 100%);
    text-align: center;
  }

  .cta-content {
    max-width: 600px;
    margin: 0 auto;
  }

  .cta-title {
    font-size: var(--text-4xl);
    font-weight: 800;
    margin-bottom: var(--space-4);
  }

  .cta-subtitle {
    font-size: var(--text-lg);
    color: var(--text-tertiary);
    margin-bottom: var(--space-8);
  }

  .btn-lg {
    padding: var(--space-4) var(--space-8);
    font-size: var(--text-base);
  }

  @media (max-width: 768px) {
    .cta-title {
      font-size: var(--text-2xl);
    }

    .cta-subtitle {
      font-size: var(--text-base);
    }

    .btn-lg {
      width: 100%;
    }
  }
</style>
