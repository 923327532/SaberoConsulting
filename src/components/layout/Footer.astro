---
import type { SupportedLocale } from '../../i18n/utils/types';
import { siteSettings } from '../../data/settings/site';
import { getNavigation } from '../../data/navigation/index';
import { t } from '../../i18n/ui/index';
import { localizeNavHref } from '../../i18n/routes/map';

interface Props {
  currentLocale: SupportedLocale;
}

const { currentLocale } = Astro.props;
const navigation = getNavigation(currentLocale);
const currentYear = new Date().getFullYear();

interface SocialIcon {
  name: string;
  url: string;
  label: string;
  path: string;
  viewBox: string;
}

const socialIcons: SocialIcon[] = [
  {
    name: 'LinkedIn',
    url: siteSettings.social.linkedin || '#',
    label: 'LinkedIn',
    viewBox: '0 0 24 24',
    path: 'M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z',
  },
  {
    name: 'Instagram',
    url: siteSettings.social.instagram || '#',
    label: 'Instagram',
    viewBox: '0 0 24 24',
    path: 'M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z',
  },
  {
    name: 'YouTube',
    url: siteSettings.social.youtube || '#',
    label: 'YouTube',
    viewBox: '0 0 24 24',
    path: 'M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z',
  },
  {
    name: 'Facebook',
    url: siteSettings.social.facebook || '#',
    label: 'Facebook',
    viewBox: '0 0 24 24',
    path: 'M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z',
  },
];

const legalLinks = [
  { key: 'footer.legal.privacy', href: '/privacidad' },
  { key: 'footer.legal.terms', href: '/terminos' },
  { key: 'footer.legal.cookies', href: '/cookies' },
  { key: 'footer.legal.cookiesPrefs', href: '#cookies-prefs' },
  { key: 'footer.legal.sitemap', href: '/sitemap-index.xml' },
];
---

<!-- ============================================
     AWS BANNER - Pre-Footer
     Degradado Moventi exacto:
     #4B00FF -> #234BFF -> #19D1C3 -> #A6E6D7
     ============================================ -->
<section class="aws-banner" aria-label="AWS Partnership">
  <div class="aws-banner-inner">
    <div class="aws-banner-left">
      <img src="/images/aws.png" alt="Amazon Web Services" class="aws-logo-img" width="52" height="32" loading="lazy" />
      <div class="aws-banner-text">
        <span class="aws-banner-title">
          Certificados por <span class="aws-banner-highlight">AWS</span>
        </span>
        <a href="#" class="aws-banner-btn">
          Conoce m&aacute;s <span class="aws-banner-arrow">&rarr;</span>
        </a>
      </div>
    </div>
    <div class="aws-banner-right">
      <p class="aws-banner-quote">&ldquo;Especialistas en modernizaci&oacute;n de aplicaciones&rdquo;</p>
    </div>
  </div>
</section>

<!-- ============================================
     FOOTER PRINCIPAL
     Fondo negro absoluto (#000000) estilo Moventi
     ============================================ -->
<footer class="site-footer" role="contentinfo">
  <div class="footer-container">
    <div class="footer-grid">
      <!-- Columna 1: Identidad -->
      <div class="footer-brand">
        <a href={currentLocale === 'es' ? '/' : `/${currentLocale}/`} class="footer-logo-link" aria-label={siteSettings.name}>
          <img src={siteSettings.logo} alt={siteSettings.name} class="footer-logo-img" width="200" height="56" loading="lazy" />
        </a>
        <p class="footer-description">{t(currentLocale, 'footer.brand.description')}</p>
        <div class="footer-social">
          {socialIcons.map((social) => (
            <a
              href={social.url}
              class="footer-social-link"
              target="_blank"
              rel="noopener noreferrer"
              aria-label={social.label}
              title={social.label}
            >
              <svg width="20" height="20" viewBox={social.viewBox} fill="currentColor" aria-hidden="true">
                <path d={social.path} />
              </svg>
            </a>
          ))}
        </div>
      </div>

      <!-- Columna 2: Contacto -->
      <div class="footer-block">
        <h3 class="footer-block-title">{t(currentLocale, 'footer.contact.title')}</h3>
        <ul class="footer-block-list">
          <li>
            <a href={`mailto:${siteSettings.contact.email}`} class="footer-link footer-link-contact">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
              <span>{siteSettings.contact.email}</span>
            </a>
          </li>
          <li>
            <a href={`https://wa.me/${siteSettings.contact.whatsapp.replace('+', '')}`} class="footer-link footer-link-contact" target="_blank" rel="noopener noreferrer">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              <span>{t(currentLocale, 'footer.contact.whatsapp')}</span>
            </a>
          </li>
          <li class="footer-contact-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            <span>{t(currentLocale, 'footer.contact.location')}</span>
          </li>
          <li>
            <a href={localizeNavHref('/contacto', currentLocale)} class="footer-link footer-link-cta">
              {t(currentLocale, 'footer.contact.form')}
            </a>
          </li>
        </ul>
      </div>

      <!-- Columna 3: Navegacion -->
      <div class="footer-block">
        <h3 class="footer-block-title">{t(currentLocale, 'footer.navigation.title')}</h3>
        <ul class="footer-block-list">
          {navigation.main.map((item) => (
            <li>
              <a href={localizeNavHref(item.href, currentLocale)} class="footer-link">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Columna 4: Mantente Informado -->
      <div class="footer-block footer-newsletter">
        <h3 class="footer-block-title">{t(currentLocale, 'footer.newsletter.title')}</h3>
        <p class="footer-newsletter-text">{t(currentLocale, 'footer.newsletter.text')}</p>
        <form class="footer-newsletter-form" action="#" method="post" data-newsletter>
          <div class="newsletter-input-group">
            <input
              type="email"
              name="email"
              class="newsletter-input"
              placeholder={t(currentLocale, 'footer.newsletter.placeholder')}
              aria-label={t(currentLocale, 'footer.newsletter.placeholder')}
              required
            />
            <button type="submit" class="newsletter-btn" aria-label={t(currentLocale, 'footer.newsletter.button')}>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <line x1="22" y1="2" x2="11" y2="13"/>
                <polygon points="22 2 15 22 11 13 2 9 22 2"/>
              </svg>
            </button>
          </div>
        </form>
        <p class="footer-newsletter-disclaimer">{t(currentLocale, 'footer.newsletter.disclaimer')}</p>
      </div>
    </div>

    <!-- Legal bottom bar -->
    <div class="footer-legal-bar">
      <div class="footer-legal-links">
        {legalLinks.map((link) => (
          <a
            href={link.href.startsWith('#') ? link.href : localizeNavHref(link.href, currentLocale)}
            class="footer-legal-link"
          >
            {t(currentLocale, link.key)}
          </a>
        ))}
      </div>
      <p class="footer-copyright">
        &copy; {currentYear} {siteSettings.name}. {t(currentLocale, 'footer.copyright')}
      </p>
    </div>
  </div>
</footer>

<script>
  document.querySelectorAll('[data-newsletter]').forEach((form) => {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const input = form.querySelector('.newsletter-input') as HTMLInputElement;
      if (input?.value) {
        input.value = '';
        input.placeholder = 'Gracias por suscribirte!';
        setTimeout(() => {
          input.placeholder = 'Tu correo electronico';
        }, 3000);
      }
    });
  });
</script>

<style>
  /* ============================================
     AWS BANNER - Pre-Footer
     Degradado Moventi exacto:
     #4B00FF -> #234BFF -> #19D1C3 -> #A6E6D7
     ============================================ */

  .aws-banner {
    width: 100%;
    background: linear-gradient(
      90deg,
      #4B00FF 0%,
      #234BFF 35%,
      #19D1C3 75%,
      #A6E6D7 100%
    );
    padding: 50px 8%;
    display: flex;
    align-items: center;
    box-sizing: border-box;
  }

  .aws-banner-inner {
    width: 100%;
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 60px;
  }

  .aws-banner-left {
    display: flex;
    align-items: center;
    gap: 28px;
    flex-shrink: 0;
  }

  .aws-logo-img {
    flex-shrink: 0;
    filter: brightness(0) invert(1);
  }

  .aws-banner-text {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .aws-banner-title {
    font-family: 'Inter', 'Montserrat', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    font-size: 28px;
    font-weight: 700;
    color: #ffffff;
    line-height: 1.2;
  }

  .aws-banner-highlight {
    color: #FFCC33;
  }

  .aws-banner-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 12px 28px;
    font-size: 15px;
    font-weight: 600;
    font-family: 'Inter', 'Montserrat', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    color: #234BFF;
    background-color: #ffffff;
    border: none;
    border-radius: 24px;
    text-decoration: none;
    transition: all 0.3s ease;
    width: fit-content;
  }

  .aws-banner-btn:hover {
    background-color: #f0f4ff;
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
  }

  .aws-banner-arrow {
    font-size: 16px;
    transition: transform 0.2s ease;
  }

  .aws-banner-btn:hover .aws-banner-arrow {
    transform: translateX(3px);
  }

  .aws-banner-right {
    flex-shrink: 0;
    max-width: 440px;
  }

  .aws-banner-quote {
    font-family: 'Inter', 'Montserrat', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    font-size: 26px;
    font-weight: 700;
    font-style: italic;
    color: #ffffff;
    line-height: 1.4;
    margin: 0;
    text-align: right;
    letter-spacing: -0.01em;
  }

  /* ============================================
     FOOTER PRINCIPAL
     Fondo negro absoluto (#000000) estilo Moventi
     ============================================ */

  .site-footer {
    width: 100%;
    background-color: #000000;
    position: relative;
  }

  .footer-container {
    width: 100%;
    padding: 70px 8% 40px;
    box-sizing: border-box;
  }

  /* ---- Grid: 4 columnas ---- */
  .footer-grid {
    display: flex;
    justify-content: space-between;
    gap: 60px;
    padding-bottom: 50px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
  }

  .footer-brand {
    flex: 1.4;
    max-width: 320px;
  }

  .footer-block {
    flex: 1;
  }

  .footer-newsletter {
    flex: 1.2;
  }

  /* ---- Brand ---- */
  .footer-logo-link {
    display: inline-flex;
    margin-bottom: 20px;
  }

  .footer-logo-img {
    display: block;
    height: 56px;
    width: auto;
    max-width: 100%;
    filter: brightness(0) invert(1);
  }

  .footer-description {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.75);
    line-height: 1.8;
    margin-bottom: 24px;
  }

  .footer-social {
    display: flex;
    gap: 16px;
  }

  .footer-social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    color: #ffffff;
    transition: color 0.2s ease;
    text-decoration: none;
  }

  .footer-social-link:hover {
    color: #3B82F6;
  }

  .footer-social-link:focus-visible {
    outline: 2px solid #ffffff;
    outline-offset: 4px;
    border-radius: 4px;
  }

  /* ---- Blocks ---- */
  .footer-block-title {
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1.2px;
    color: #ffffff;
    margin-bottom: 24px;
    padding-bottom: 14px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
  }

  .footer-block-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer-link {
    font-size: 14px;
    color: #ffffff;
    text-decoration: none;
    transition: color 0.2s ease;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 4px 0;
  }

  .footer-link:hover {
    color: #3B82F6;
  }

  .footer-link:focus-visible {
    outline: 2px solid #ffffff;
    outline-offset: 2px;
    border-radius: 4px;
  }

  .footer-link-contact {
    gap: 8px;
  }

  .footer-link-contact svg {
    flex-shrink: 0;
    opacity: 0.7;
  }

  .footer-link-contact:hover svg {
    opacity: 1;
  }

  .footer-contact-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: rgba(255, 255, 255, 0.75);
    padding: 4px 0;
  }

  .footer-contact-item svg {
    flex-shrink: 0;
    opacity: 0.7;
  }

  .footer-link-cta {
    color: #ffffff;
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 3px;
    margin-top: 8px;
  }

  .footer-link-cta:hover {
    color: #3B82F6;
  }

  /* ---- Newsletter ---- */
  .footer-newsletter-text {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.75);
    line-height: 1.7;
    margin-bottom: 20px;
  }

  .newsletter-input-group {
    display: flex;
    gap: 0;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 8px;
    overflow: hidden;
    transition: border-color 0.2s ease;
  }

  .newsletter-input-group:focus-within {
    border-color: #3B82F6;
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.15);
  }

  .newsletter-input {
    flex: 1;
    padding: 14px 16px;
    font-size: 14px;
    color: #ffffff;
    background-color: rgba(255, 255, 255, 0.06);
    border: none;
    outline: none;
    font-family: inherit;
  }

  .newsletter-input::placeholder {
    color: rgba(255, 255, 255, 0.35);
  }

  .newsletter-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    flex-shrink: 0;
    background-color: rgba(255, 255, 255, 0.1);
    color: #ffffff;
    border: none;
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .newsletter-btn:hover {
    background-color: rgba(59, 130, 246, 0.2);
    color: #3B82F6;
  }

  .newsletter-btn:focus-visible {
    outline: 2px solid #ffffff;
    outline-offset: -2px;
  }

  .footer-newsletter-disclaimer {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.35);
    margin-top: 14px;
    margin-bottom: 0;
  }

  /* ---- Legal bar ---- */
  .footer-legal-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 28px 0 0;
    gap: 30px;
    flex-wrap: wrap;
  }

  .footer-legal-links {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }

  .footer-legal-link {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.5);
    text-decoration: none;
    padding: 4px 10px;
    border-radius: 4px;
    transition: color 0.2s ease;
    white-space: nowrap;
  }

  .footer-legal-link:hover {
    color: #3B82F6;
  }

  .footer-legal-link:focus-visible {
    outline: 2px solid #ffffff;
    outline-offset: 2px;
  }

  .footer-copyright {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 0;
    white-space: nowrap;
  }

  /* ============================================
     Responsive
     ============================================ */

  @media (max-width: 1100px) {
    .aws-banner {
      padding: 40px 8%;
    }

    .aws-banner-inner {
      flex-direction: column;
      text-align: center;
      gap: 30px;
    }

    .aws-banner-left {
      flex-direction: column;
      align-items: center;
    }

    .aws-banner-text {
      align-items: center;
    }

    .aws-banner-right {
      max-width: 100%;
    }

    .aws-banner-quote {
      text-align: center;
      font-size: 22px;
    }

    .footer-grid {
      flex-wrap: wrap;
      gap: 40px;
    }

    .footer-brand {
      flex: 1 1 100%;
      max-width: 100%;
    }

    .footer-block {
      flex: 1 1 45%;
    }

    .footer-newsletter {
      flex: 1 1 45%;
    }
  }

  @media (max-width: 768px) {
    .aws-banner {
      padding: 30px 5%;
    }

    .aws-banner-title {
      font-size: 22px;
    }

    .aws-banner-quote {
      font-size: 18px;
    }

    .footer-container {
      padding: 50px 5% 30px;
    }

    .footer-grid {
