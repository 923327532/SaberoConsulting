---
import { LOCALE_SHORT, LOCALE_LABELS, LOCALES, DEFAULT_LOCALE } from '../../i18n/utils/types';
import type { SupportedLocale } from '../../i18n/utils/types';
import { t } from '../../i18n/ui/index';

interface Props {
  currentLocale: SupportedLocale;
  path: string;
  variant?: 'desktop' | 'mobile';
}

const { currentLocale, path, variant = 'desktop' } = Astro.props;

function getLocalizedHref(locale: SupportedLocale): string {
  const segments = path.split('/').filter(Boolean);
  if (LOCALES.includes(segments[0] as SupportedLocale)) {
    segments[0] = locale;
  } else {
    segments.unshift(locale);
  }
  if (locale === DEFAULT_LOCALE) {
    segments.shift();
  }
  // Siempre con trailing slash para compatibilidad con trailingSlash: 'always'
  return '/' + segments.join('/') + '/';
}
---

{
  variant === 'desktop' ? (
    <nav class="lang-switcher" aria-label="Language selector">
      <button class="lang-current" aria-haspopup="true" aria-expanded="false" data-lang-toggle>
        <span class="lang-current-code">{LOCALE_SHORT[currentLocale]}</span>
        <svg width="8" height="5" viewBox="0 0 8 5" fill="none" aria-hidden="true">
          <path d="M1 1l3 3 3-3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <div class="lang-dropdown" data-lang-dropdown>
        {LOCALES.map((locale) => (
          <a
            href={getLocalizedHref(locale)}
            hreflang={locale}
            class={`lang-option ${locale === currentLocale ? 'active' : ''}`}
            aria-current={locale === currentLocale ? 'true' : undefined}
          >
            <span class="lang-option-code">{LOCALE_SHORT[locale]}</span>
            <span class="lang-option-name">{LOCALE_LABELS[locale]}</span>
          </a>
        ))}
      </div>
    </nav>
  ) : (
    <nav class="lang-switcher-mobile" aria-label="Language selector">
      <span class="lang-mobile-label">{t(currentLocale, 'language.label')}</span>
      <div class="lang-mobile-options">
        {LOCALES.map((locale) => (
          <a
            href={getLocalizedHref(locale)}
            hreflang={locale}
            class={`lang-mobile-option ${locale === currentLocale ? 'active' : ''}`}
            aria-current={locale === currentLocale ? 'true' : undefined}
          >
            <span class="lang-mobile-code">{LOCALE_SHORT[locale]}</span>
            <span class="lang-mobile-name">{LOCALE_LABELS[locale]}</span>
          </a>
        ))}
      </div>
    </nav>
  )
}

<script>
  document.querySelectorAll('[data-lang-toggle]').forEach((btn) => {
    const dropdown = btn.parentElement?.querySelector('[data-lang-dropdown]') as HTMLElement;

    function toggle() {
      const isOpen = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!isOpen));
      dropdown?.classList.toggle('open', !isOpen);
    }

    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      toggle();
    });

    btn.addEventListener('keydown', (e: Event) => {
      const ke = e as KeyboardEvent;
      if (ke.key === 'Enter' || ke.key === ' ') {
        ke.preventDefault();
        toggle();
      }
    });
  });

  document.addEventListener('click', (e) => {
    // No cerrar si el clic fue en un enlace del dropdown (para no bloquear navegacion)
    const target = e.target as HTMLElement;
    if (target.closest('.lang-option, .lang-mobile-option')) return;
    document.querySelectorAll('[data-lang-dropdown].open').forEach((d) => d.classList.remove('open'));
    document.querySelectorAll('[data-lang-toggle][aria-expanded="true"]').forEach((b) => b.setAttribute('aria-expanded', 'false'));
  });
</script>

<style>
  /* ============================================
     Language Switcher - Minimalista
     Sin recuadro, solo texto + flecha
     ============================================ */

  .lang-switcher {
    position: relative;
  }

  .lang-current {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 0;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-gray-500);
    background: none;
    border: none;
    cursor: pointer;
    transition: color var(--transition-fast);
    letter-spacing: 0.5px;
    text-transform: uppercase;
    font-family: inherit;
    line-height: 1;
  }

  .lang-current:hover {
    color: var(--color-deep-blue);
  }

  .lang-current:focus-visible {
    outline: 2px solid var(--accent-color);
    outline-offset: 4px;
    border-radius: 2px;
  }

  .lang-current-code {
    font-size: var(--text-xs);
    font-weight: 600;
  }

  .lang-dropdown {
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    min-width: 140px;
    background-color: var(--color-white);
    border: 1px solid var(--color-gray-100);
    border-radius: var(--radius-md);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition: all var(--transition-fast);
    z-index: 50;
    overflow: hidden;
  }

  .lang-dropdown.open {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .lang-option {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-2) var(--space-3);
    text-decoration: none;
    transition: background-color var(--transition-fast);
  }

  .lang-option:hover {
    background-color: var(--color-gray-50);
  }

  .lang-option.active {
    background-color: var(--color-gray-50);
  }

  .lang-option-code {
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--accent-color);
    min-width: 24px;
    text-transform: uppercase;
  }

  .lang-option-name {
    font-size: var(--text-sm);
    color: var(--color-gray-500);
  }

  .lang-option.active .lang-option-name {
    color: var(--color-deep-blue);
    font-weight: 500;
  }

  /* ---- Mobile variant ---- */
  .lang-switcher-mobile {
    padding: var(--space-4) var(--space-6);
    border-top: 1px solid var(--color-gray-100);
  }

  .lang-mobile-label {
    display: block;
    font-size: var(--text-xs);
    color: var(--color-gray-400);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: var(--space-3);
    font-weight: 600;
  }

  .lang-mobile-options {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-2);
  }

  .lang-mobile-option {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-3);
    text-decoration: none;
    background-color: var(--color-gray-50);
    border: 1px solid var(--color-gray-100);
    border-radius: var(--radius-md);
    transition: all var(--transition-fast);
  }

  .lang-mobile-option:hover {
    background-color: var(--color-gray-100);
  }

  .lang-mobile-option.active {
    border-color: var(--accent-color);
    background-color: rgba(0, 102, 255, 0.05);
  }

  .lang-mobile-code {
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--accent-color);
    min-width: 24px;
    text-transform: uppercase;
  }

  .lang-mobile-name {
    font-size: var(--text-sm);
    color: var(--color-gray-500);
  }

  .lang-mobile-option.active .lang-mobile-name {
    color: var(--color-deep-blue);
    font-weight: 500;
  }
</style>
